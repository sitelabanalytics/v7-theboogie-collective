---
// Branded triangle overlay
// Rules: all triangles point DOWN (inverted), no rotation, scale outward only
// One center outline repeats expanding from center
---

<div class="aro-wrap" aria-hidden="true">
  <svg class="aro-svg" viewBox="0 0 1920 1080" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">

    <!-- Center repeating outline — expands outward from center -->
    <polygon class="aro-center aro-c1" points="960,340 1160,740 760,740" />
    <polygon class="aro-center aro-c2" points="960,340 1160,740 760,740" />
    <polygon class="aro-center aro-c3" points="960,340 1160,740 760,740" />
    <polygon class="aro-center aro-c4" points="960,340 1160,740 760,740" />

    <!-- Difference fill — single inverted triangle, scale outward -->
    <polygon class="aro-diff aro-d1" points="960,500 1200,100 720,100" />

    <!-- Large outlines — inverted, expand outward -->
    <polygon class="aro-outline aro-ol1" points="960,570 1260,50 660,50" />
    <polygon class="aro-outline aro-ol2" points="250,900 550,300 -50,300" />
    <polygon class="aro-outline aro-ol3" points="1700,800 2000,250 1400,250" />
    <polygon class="aro-outline aro-ol4" points="600,500 800,150 400,150" />
    <polygon class="aro-outline aro-ol5" points="1400,450 1600,100 1200,100" />
    <polygon class="aro-outline aro-ol6" points="100,600 350,150 -150,150" />
    <polygon class="aro-outline aro-ol7" points="1800,500 2050,50 1550,50" />
    <polygon class="aro-outline aro-ol8" points="960,850 1200,400 720,400" />
    <polygon class="aro-outline aro-ol9" points="500,750 700,350 300,350" />
    <polygon class="aro-outline aro-ol10" points="1500,700 1700,300 1300,300" />

    <!-- Medium outlines — inverted -->
    <polygon class="aro-outline-med aro-om1" points="480,440 620,200 340,200" />
    <polygon class="aro-outline-med aro-om2" points="1400,420 1540,180 1260,180" />
    <polygon class="aro-outline-med aro-om3" points="960,640 1100,400 820,400" />
    <polygon class="aro-outline-med aro-om4" points="300,840 440,600 160,600" />
    <polygon class="aro-outline-med aro-om5" points="1600,790 1740,550 1460,550" />
    <polygon class="aro-outline-med aro-om6" points="750,890 890,650 610,650" />
    <polygon class="aro-outline-med aro-om7" points="150,350 290,110 10,110" />
    <polygon class="aro-outline-med aro-om8" points="1200,300 1340,60 1060,60" />
    <polygon class="aro-outline-med aro-om9" points="700,200 840,-40 560,-40" />
    <polygon class="aro-outline-med aro-om10" points="1750,500 1890,260 1610,260" />
    <polygon class="aro-outline-med aro-om11" points="400,600 540,360 260,360" />
    <polygon class="aro-outline-med aro-om12" points="1100,750 1240,510 960,510" />

    <!-- Small outlines — inverted -->
    <polygon class="aro-outline-sm aro-os1" points="200,240 270,120 130,120" />
    <polygon class="aro-outline-sm aro-os2" points="1720,280 1790,160 1650,160" />
    <polygon class="aro-outline-sm aro-os3" points="580,500 650,380 510,380" />
    <polygon class="aro-outline-sm aro-os4" points="1100,440 1170,320 1030,320" />
    <polygon class="aro-outline-sm aro-os5" points="400,840 470,720 330,720" />
    <polygon class="aro-outline-sm aro-os6" points="1500,800 1570,680 1430,680" />
    <polygon class="aro-outline-sm aro-os7" points="850,900 920,780 780,780" />
    <polygon class="aro-outline-sm aro-os8" points="1200,870 1270,750 1130,750" />
    <polygon class="aro-outline-sm aro-os9" points="50,500 120,380 -20,380" />
    <polygon class="aro-outline-sm aro-os10" points="1850,600 1920,480 1780,480" />
    <polygon class="aro-outline-sm aro-os11" points="350,150 420,30 280,30" />
    <polygon class="aro-outline-sm aro-os12" points="1350,200 1420,80 1280,80" />
    <polygon class="aro-outline-sm aro-os13" points="700,700 770,580 630,580" />
    <polygon class="aro-outline-sm aro-os14" points="1600,450 1670,330 1530,330" />
    <polygon class="aro-outline-sm aro-os15" points="250,700 320,580 180,580" />
    <polygon class="aro-outline-sm aro-os16" points="1050,150 1120,30 980,30" />

  </svg>
</div>

<style is:global>
  .aro-wrap {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    overflow: hidden;
  }
  .aro-svg {
    width: 100%;
    height: 100%;
  }

  /* ─── Center repeating outline — pulses outward from center ─── */
  .aro-center {
    fill: none;
    stroke: rgba(255, 255, 255, 0.15);
    stroke-width: 0.8;
    transform-origin: 960px 540px;
  }
  .aro-c1 { animation: aroExpand 8s ease-out 0s infinite; }
  .aro-c2 { animation: aroExpand 8s ease-out 2s infinite; }
  .aro-c3 { animation: aroExpand 8s ease-out 4s infinite; }
  .aro-c4 { animation: aroExpand 8s ease-out 6s infinite; }

  @keyframes aroExpand {
    0%   { opacity: 0.6; transform: scale(0.3); }
    60%  { opacity: 0.2; }
    100% { opacity: 0; transform: scale(2.5); }
  }

  /* ─── Difference fills — scale outward, no rotation ─── */
  .aro-diff {
    fill: rgba(255, 255, 255, 0.35);
    stroke: none;
    mix-blend-mode: difference;
    transform-origin: center;
  }
  .aro-d1 { animation: aroDiff 18s ease-in-out 0s infinite; }

  @keyframes aroDiff {
    0%   { opacity: 0; transform: scale(0.85); }
    15%  { opacity: 1; transform: scale(1); }
    45%  { opacity: 0.5; transform: scale(1.15); }
    70%  { opacity: 0.9; transform: scale(1.08); }
    100% { opacity: 0; transform: scale(1.25); }
  }

  /* ─── Large outlines — expand outward ─── */
  .aro-outline {
    fill: none;
    stroke: rgba(107, 0, 204, 0.2);
    stroke-width: 1;
    transform-origin: center;
  }
  .aro-ol1 { animation: aroOut 24s ease-in-out 0s infinite; }
  .aro-ol2 { animation: aroOut 28s ease-in-out 5s infinite; }
  .aro-ol3 { animation: aroOut 26s ease-in-out 10s infinite; }
  .aro-ol4 { animation: aroOut 22s ease-in-out 14s infinite; }
  .aro-ol5 { animation: aroOut 30s ease-in-out 18s infinite; }
  .aro-ol6 { animation: aroOut 25s ease-in-out 3s infinite; }
  .aro-ol7 { animation: aroOut 27s ease-in-out 8s infinite; }
  .aro-ol8 { animation: aroOut 23s ease-in-out 12s infinite; }
  .aro-ol9 { animation: aroOut 29s ease-in-out 16s infinite; }
  .aro-ol10 { animation: aroOut 21s ease-in-out 20s infinite; }

  @keyframes aroOut {
    0%   { opacity: 0; transform: scale(0.9); }
    20%  { opacity: 0.6; transform: scale(1); }
    50%  { opacity: 0.2; transform: scale(1.12); }
    75%  { opacity: 0.5; transform: scale(1.18); }
    100% { opacity: 0; transform: scale(1.25); }
  }

  /* ─── Medium outlines — orange ─── */
  .aro-outline-med {
    fill: none;
    stroke: rgba(255, 102, 17, 0.15);
    stroke-width: 0.8;
    transform-origin: center;
  }
  .aro-om1 { animation: aroOut 20s ease-in-out 0s infinite; }
  .aro-om2 { animation: aroOut 22s ease-in-out 3s infinite; }
  .aro-om3 { animation: aroOut 18s ease-in-out 6s infinite; }
  .aro-om4 { animation: aroOut 24s ease-in-out 9s infinite; }
  .aro-om5 { animation: aroOut 20s ease-in-out 12s infinite; }
  .aro-om6 { animation: aroOut 22s ease-in-out 15s infinite; }
  .aro-om7 { animation: aroOut 19s ease-in-out 1s infinite; }
  .aro-om8 { animation: aroOut 21s ease-in-out 4s infinite; }
  .aro-om9 { animation: aroOut 17s ease-in-out 7s infinite; }
  .aro-om10 { animation: aroOut 23s ease-in-out 10s infinite; }
  .aro-om11 { animation: aroOut 19s ease-in-out 13s infinite; }
  .aro-om12 { animation: aroOut 21s ease-in-out 16s infinite; }

  /* ─── Small outlines — white ─── */
  .aro-outline-sm {
    fill: none;
    stroke: rgba(255, 255, 255, 0.12);
    stroke-width: 0.6;
    transform-origin: center;
  }
  .aro-os1 { animation: aroOut 14s ease-in-out 0s infinite; }
  .aro-os2 { animation: aroOut 16s ease-in-out 2s infinite; }
  .aro-os3 { animation: aroOut 12s ease-in-out 4s infinite; }
  .aro-os4 { animation: aroOut 18s ease-in-out 5s infinite; }
  .aro-os5 { animation: aroOut 14s ease-in-out 7s infinite; }
  .aro-os6 { animation: aroOut 16s ease-in-out 9s infinite; }
  .aro-os7 { animation: aroOut 12s ease-in-out 10s infinite; }
  .aro-os8 { animation: aroOut 18s ease-in-out 12s infinite; }
  .aro-os9 { animation: aroOut 13s ease-in-out 1s infinite; }
  .aro-os10 { animation: aroOut 15s ease-in-out 3s infinite; }
  .aro-os11 { animation: aroOut 11s ease-in-out 5s infinite; }
  .aro-os12 { animation: aroOut 17s ease-in-out 6s infinite; }
  .aro-os13 { animation: aroOut 13s ease-in-out 8s infinite; }
  .aro-os14 { animation: aroOut 15s ease-in-out 10s infinite; }
  .aro-os15 { animation: aroOut 11s ease-in-out 11s infinite; }
  .aro-os16 { animation: aroOut 17s ease-in-out 13s infinite; }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .aro-diff, .aro-outline, .aro-outline-med, .aro-outline-sm, .aro-center {
      animation: none !important;
      opacity: 0.1;
    }
  }
</style>
