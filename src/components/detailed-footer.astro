---
// @ts-ignore
import { Icon } from "astro-icon";
---

<style>
  .footer-wrapper {
    margin: 0;
    padding: 0;
    width: 100%;
    overflow: hidden;
  }

  .footer-hero {
    position: relative;
    background-image: url('../assets/tbc/uv-banners.jpg');
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center;
    width: 100%;
  }

  .footer-hero-overlay {
    position: relative;
    z-index: 1;
  }

  .glass-card {
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    padding: 2rem;
    max-width: 40rem;
  }

  .glass-card .label {
    font-family: 'Inconsolata', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 0.5rem;
  }

  .glass-card h3 {
    font-family: 'Centauri', sans-serif;
  }

  .glass-card p {
    font-family: 'Wotfard', sans-serif;
    font-weight: 500;
  }

  .photo-credit {
    font-family: 'Inconsolata', monospace;
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.4);
    position: absolute;
    bottom: 1rem;
    right: 1.5rem;
    z-index: 2;
    letter-spacing: 0.03em;
  }

  .footer-links {
    background-color: #000;
    width: 100%;
  }

  .footer-links h5 {
    font-family: 'Centauri', sans-serif;
  }

  .footer-links ul {
    font-family: 'Wotfard', sans-serif;
    font-weight: 500;
  }

  .footer-links a {
    font-size: 0.85rem;
    color: rgb(148, 163, 184);
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: #fff;
  }

  .footer-brand-name {
    font-family: 'Centauri', sans-serif;
  }

  .footer-copyright {
    font-family: 'Wotfard', sans-serif;
    font-weight: 500;
  }
</style>

<div class="footer-wrapper">
  <!-- Part 1: Hero image section -->
  <section class="footer-hero pt-64 lg:pt-96 pb-16 lg:pb-20">
    <div class="footer-hero-overlay mb-4 md:mb-8 mx-4 md:mx-8">
      <div class="glass-card">
        <p class="label">Artists</p>
        <h3 class="text-2xl md:text-3xl lg:text-5xl mb-4 font-bold lg:tracking-tight text-white">
          Helping you stop dancing inside.
        </h3>
        <p class="text-md lg:text-lg text-gray-200">
          Local and nationally touring artists from across the Eastern Australian Coast. The Boogie Collective is a platform for booking better underground artists.
        </p>
        <div class="mt-6 flex flex-col sm:flex-row justify-start gap-3">
          <a href="/artists" rel="noopener" class="rounded text-center transition focus-visible:ring-2 ring-offset-2 ring-gray-200 px-5 py-2.5 bg-white text-black hover:bg-gray-200 border-2 border-transparent flex gap-1 items-center justify-center font-medium">
            <svg viewBox="0 0 24 24" class="w-4 h-4">
              <Icon class="text-black" name="ph:codepen-logo-light" />
            </svg>
            Artists
          </a>
        </div>
      </div>
    </div>
    <span class="photo-credit">Dan Martin Photography</span>
  </section>

  <!-- Part 2: Black footer links section -->
  <footer class="footer-links py-10 lg:py-20 flex flex-col md:flex-row items-start">
    <div class="w-full md:w-2/3 grid grid-cols-2 px-4 lg:px-8">
      <div>
        <h5 class="text-sm font-semibold text-white mb-4">Links</h5>
        <ul class="list-none">
          <li class="mb-2"><a href="/">Home</a></li>
          <li class="mb-2"><a href="/about">About</a></li>
          <li class="mb-2"><a href="/artists">Artists</a></li>
          <li class="mb-2"><a href="/events">Events</a></li>
          <li class="mb-2"><a href="/shop">Shop</a></li>
          <li class="mb-2"><a href="https://facebook.com/theboogiecollective/">Facebook</a></li>
          <li class="mb-2"><a href="https://instagram.com/theboogiecollective/">Instagram</a></li>
        </ul>
      </div>
      <div>
        <h5 class="text-sm font-semibold text-white mb-4">Orders</h5>
        <ul class="list-none">
          <li class="mb-2"><a href="https://billing.stripe.com/p/login/5kA4jQdGtb9m8N2fYY" target="_blank" rel="noopener">Manage Order / Refund</a></li>
          <li class="mb-2"><a href="https://theboogiecollective.com/terms">Terms of Service</a></li>
          <li class="mb-2"><a href="https://theboogiecollective.com/conditions">Privacy Policy</a></li>
          <li class="mb-2"><a href="https://theboogiecollective.com/contact">Contact</a></li>
        </ul>
      </div>
    </div>
    <div class="w-full md:w-1/3 px-4 lg:px-8 mt-8 md:mt-0 flex flex-col items-start">
      <p class="footer-brand-name text-xl font-normal text-white">
        The Boogie Collective
      </p>
      <p class="footer-copyright text-xs lg:text-sm text-gray-300 mt-4">
        &copy; {new Date().getFullYear()} The Boogie Collective. All rights reserved.
      </p>
    </div>
  </footer>
</div>
