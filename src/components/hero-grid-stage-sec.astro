---
const features = [
  {
    title: "Stage Design",
    description: "Specialising in bamboo construction of immersive 3D shapes and designs.",
    image: "/event-6.jpg",
  },
  {
    title: "Shade Installations",
    description: "Hire our unique, fast install shades. Requiring less rigging.",
    image: "/event-4.jpg",
  },
  {
    title: "Lighting",
    description: "Expertly crafted lighting installations with minimal power usage.",
    image: "/event-1.jpg",
  },
  {
    title: "Art Installations",
    description: "Our own unique art installations for outdoor events, coloured to your event.",
    image: "/event-5.jpg",
  },
  {
    title: "Event Management",
    description: "Over 4 years experience in event management and artist liaison.",
    image: "/event-3.jpg",
  },
  {
    title: "Stage Management",
    description: "With over 5 years experience helping manage stages across numerous events.",
    image: "/event-2.webp",
  },
  {
    title: "Web Design",
    description: "We have experience designing and developing over 20 events and ticketing websites.",
    image: "/event-1.jpg",
  },
  {
    title: "Digital Marketing",
    description: "Helping over 10 events outside of our own with maximising their marketing budget.",
    image: "/event-4.jpg",
  },
];
---

<style>
  .imm-cell {
    margin-right: 12px;
    width: 72vw;
    max-width: 360px;
    height: 260px;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    border: 0.5px solid rgba(255, 255, 255, 0.08);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s;
  }
  .imm-cell:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.15);
  }
  @media (min-width: 520px) { .imm-cell { width: 50vw; max-width: 380px; margin-right: 14px; } }
  @media (min-width: 768px) { .imm-cell { width: 38vw; max-width: 400px; height: 280px; } }
  @media (min-width: 1024px) { .imm-cell { width: 28vw; max-width: 420px; margin-right: 16px; } }

  .imm-bg {
    position: absolute;
    inset: 0;
  }
  .imm-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .imm-cell:hover .imm-bg img { transform: scale(1.05); }

  .imm-grad {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.35) 50%, rgba(0,0,0,0.1) 100%);
    pointer-events: none;
    z-index: 1;
  }

  .imm-content {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    z-index: 2;
    padding: 20px;
  }
  .imm-title {
    font-size: 1rem;
    margin-bottom: 6px;
    color: #fff !important;
  }
  @media (min-width: 768px) { .imm-title { font-size: 1.15rem; } }
  .imm-desc {
    font-size: 0.75rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.5) !important;
  }

  .imm-carousel { max-width: 100vw !important; overflow: hidden; }
  .imm-carousel .flickity-viewport { min-height: 1px; overflow: visible; }
</style>

<main class="mx-auto mt-8 md:mt-12 pb-4">
  <div class="pt-4 px-5 md:px-10 lg:px-16 mb-6 flex flex-row items-end justify-between">
    <div>
      <h5 class="text-xs md:text-sm">Immersive Structures</h5>
      <h4 class="text-xl md:text-2xl lg:text-3xl my-2 font-bold lg:tracking-tight">
        What We Build.
      </h4>
    </div>
    <a href="/immersive-structures" class="rounded text-center transition px-5 py-2 text-sm border border-white/20 hover:border-white/50 text-white mb-2">
      View All
    </a>
  </div>

  <div class="imm-carousel pl-5 md:pl-10 lg:pl-16">
    {features.map((item) => (
      <div class="imm-cell">
        <div class="imm-bg">
          <img src={item.image} alt={item.title} loading="lazy" />
        </div>
        <div class="imm-grad"></div>
        <div class="imm-content">
          <h3 class="imm-title">{item.title}</h3>
          <p class="imm-desc">{item.description}</p>
        </div>
      </div>
    ))}
  </div>
</main>

<script is:inline>
  var immFlkty = new Flickity('.imm-carousel', {
    cellAlign: 'left',
    contain: true,
    prevNextButtons: false,
    pageDots: true,
    freeScroll: true,
    imagesLoaded: true
  });
</script>
