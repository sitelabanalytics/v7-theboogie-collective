---
import { Picture } from "@astrojs/image/components";
import StageCover from '../assets/tbc/gal-hh2-2.webp';
---

<div class="mx-auto max-w-7xl my-6 md:my-10 px-5 md:px-10 lg:px-16 flex flex-col-reverse md:flex-row justify-start items-center">
  <div class="w-full md:w-3/5">
    <h5 class="text-xs md:text-sm lg:text-md my-4">
      Event Installations
    </h5>
    <h3 class="max-w-3xl text-2xl md:text-3xl lg:text-4xl font-bold lg:tracking-tight">
      Immersive Structures.
    </h3>
    <p class="text-sm lg:text-lg max-w-3xl mt-4">
      3D stage design and construction across the Eastern Coast of Australia for over 50 events. Specialist in lighting design and bamboo construction.
    </p>
  </div>
  <div class="w-full md:w-2/5 p-4">
    <Picture
      src={StageCover}
      sizes="(max-width: 2000px) 2000px, 1000px"
      widths={[1000, 1500, 2000]}
      aspectRatio="1:1"
      background="#f2f2f2"
      fit="cover"
      position="center"
      class="w-full rounded duration-200 hover:shadow-sm"
    />
  </div>
</div>
