---
// Cinematic background section with crossfading images and text roller
const bgImages = [
  '/hero-bg.webp',
  '/hero-bg-mobile.webp',
  '/bg-radial.png',
];

const rollerLines = [
  'curating outdoor electronic events',
  'stage design & immersive installations',
  'artist bookings across the east coast',
  'limited release merch & apparel',
  'lighting & production design',
  'helping you stop dancing inside',
];
---

<style is:global>
  .video-section {
    position: relative;
    height: 480px;
    overflow: hidden;
    background: #000;
  }
  @media (min-width: 768px) {
    .video-section { height: 560px; }
  }

  /* Crossfading Ken Burns backgrounds */
  .video-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .video-bg-img {
    position: absolute;
    inset: 0;
    opacity: 0;
    animation: videoCrossfade 18s ease-in-out infinite;
    will-change: opacity, transform;
  }
  .video-bg-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .video-bg-img:nth-child(1) {
    animation-delay: 0s;
    animation-name: kenBurns1;
  }
  .video-bg-img:nth-child(2) {
    animation-delay: 6s;
    animation-name: kenBurns2;
  }
  .video-bg-img:nth-child(3) {
    animation-delay: 12s;
    animation-name: kenBurns3;
  }

  @keyframes kenBurns1 {
    0%    { opacity: 1; transform: scale(1); }
    28%   { opacity: 1; transform: scale(1.08); }
    33%   { opacity: 0; transform: scale(1.08); }
    95%   { opacity: 0; transform: scale(1); }
    100%  { opacity: 1; transform: scale(1); }
  }
  @keyframes kenBurns2 {
    0%    { opacity: 0; transform: scale(1.05); }
    28%   { opacity: 0; transform: scale(1); }
    33%   { opacity: 1; transform: scale(1); }
    61%   { opacity: 1; transform: scale(1.08); }
    66%   { opacity: 0; transform: scale(1.08); }
    100%  { opacity: 0; transform: scale(1.05); }
  }
  @keyframes kenBurns3 {
    0%    { opacity: 0; transform: scale(1); }
    61%   { opacity: 0; transform: scale(1.05); }
    66%   { opacity: 1; transform: scale(1); }
    94%   { opacity: 1; transform: scale(1.08); }
    100%  { opacity: 0; transform: scale(1.08); }
  }

  /* Gradient overlay */
  .video-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(0deg, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.3) 40%, rgba(0,0,0,0.2) 100%);
    pointer-events: none;
  }

  /* Content */
  .video-content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0 20px 48px;
  }
  @media (min-width: 768px) { .video-content { padding: 0 40px 60px; } }
  @media (min-width: 1024px) { .video-content { padding: 0 64px 60px; } }

  .video-headline {
    font-size: 2rem;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 8px;
  }
  @media (min-width: 768px) { .video-headline { font-size: 3rem; } }
  @media (min-width: 1024px) { .video-headline { font-size: 3.8rem; } }

  /* Text roller */
  .text-roller {
    display: inline-block;
    height: 1.15em;
    overflow: hidden;
    vertical-align: bottom;
  }
  .text-roller-inner {
    display: inline-flex;
    flex-direction: column;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .text-roller-item {
    height: 1.15em;
    display: flex;
    align-items: center;
    white-space: nowrap;
    background: linear-gradient(135deg, #6B00CC, #FF6611);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .video-sub {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4) !important;
    margin-top: 12px;
    max-width: 400px;
  }
</style>

<section class="video-section">
  <!-- Crossfading backgrounds -->
  <div class="video-bg">
    {bgImages.map((src, i) => (
      <div class="video-bg-img">
        <img src={src} alt="" loading="lazy" />
      </div>
    ))}
  </div>

  <div class="video-gradient"></div>

  <!-- Content -->
  <div class="video-content px-5 md:px-10 lg:px-16">
    <h2 class="video-headline">
      We're<br>
      <span class="text-roller" id="videoRoller">
        <span class="text-roller-inner" id="videoRollerInner">
          {rollerLines.map((line) => (
            <span class="text-roller-item">{line}</span>
          ))}
        </span>
      </span>
    </h2>
    <p class="video-sub">
      The Boogie Collective — outdoor electronic music events, artist bookings, and immersive stage installations across the Australian east coast.
    </p>
  </div>
</section>

<script is:inline>
  (function() {
    var lines = 6;
    var index = 0;
    var inner = document.getElementById('videoRollerInner');
    if (!inner) return;
    setInterval(function() {
      index = (index + 1) % lines;
      inner.style.transform = 'translateY(-' + (index * (100 / lines)) + '%)';
    }, 2800);
  })();
</script>
