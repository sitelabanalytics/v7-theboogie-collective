---
const silentLinks = [
  { label: 'Events', href: '/events' },
  { label: 'Boog.VJ', href: '/boog-vj' },
  { label: 'Installations', href: '/immersive-structures' },
  { label: 'Shop', href: '/shop' },
];
---

<style is:global>
  .video-section {
    position: relative;
    height: 560px;
    overflow: hidden;
    background: #000;
  }
  @media (min-width: 768px) {
    .video-section { height: 640px; }
  }

  /* Video background */
  .video-bg-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .video-bg-wrap video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .video-bg-desktop { display: block; }
  .video-bg-mobile { display: none; }
  @media (max-width: 768px) {
    .video-bg-desktop { display: none; }
    .video-bg-mobile { display: block; }
  }

  /* Gradient overlay */
  .video-gradient {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(0deg, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.4) 35%, rgba(0,0,0,0.1) 60%, rgba(0,0,0,0.25) 100%);
    pointer-events: none;
  }

  /* Content */
  .video-content {
    position: relative;
    z-index: 3;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: 48px;
  }
  @media (min-width: 768px) { .video-content { padding-bottom: 60px; } }

  .video-label {
    font-family: 'inconsolata' !important;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.35) !important;
    margin-bottom: 12px;
  }

  .video-headline {
    font-family: 'idlewild' !important;
    font-size: 1.1rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 0;
    mix-blend-mode: difference;
    color: #fff !important;
  }
  @media (min-width: 480px) { .video-headline { font-size: 1.4rem; } }
  @media (min-width: 768px) { .video-headline { font-size: 2.2rem; } }
  @media (min-width: 1024px) { .video-headline { font-size: 2.8rem; } }
  @media (min-width: 1280px) { .video-headline { font-size: 3.2rem; } }

  /* ─── Silent buttons ─── */
  .silent-btns {
    display: flex;
    gap: 8px;
    margin-top: 24px;
    flex-wrap: wrap;
  }
  @media (min-width: 768px) { .silent-btns { gap: 10px; margin-top: 28px; } }

  .silent-btn {
    display: inline-flex;
    align-items: center;
    padding: 8px 20px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 0.5px solid rgba(255, 255, 255, 0.08);
    font-family: 'inconsolata' !important;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.5) !important;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    white-space: nowrap;
  }
  .silent-btn:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.85) !important;
  }
  @media (min-width: 768px) {
    .silent-btn { padding: 9px 24px; font-size: 0.65rem; }
  }

  /* ─── Secondary nav row ─── */
  .video-subnav {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 14px 20px;
    background: rgba(255, 255, 255, 0.02);
    border-top: 0.5px solid rgba(255, 255, 255, 0.06);
    border-bottom: 0.5px solid rgba(255, 255, 255, 0.06);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  @media (min-width: 768px) {
    .video-subnav { gap: 6px; padding: 16px 40px; }
  }

  .subnav-link {
    display: inline-flex;
    align-items: center;
    padding: 6px 8px;
    border-radius: 6px;
    font-family: 'inconsolata' !important;
    font-size: 0.45rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.35) !important;
    text-decoration: none;
    transition: all 0.25s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  @media (min-width: 480px) { .subnav-link { font-size: 0.5rem; padding: 6px 12px; } }
  @media (min-width: 768px) { .subnav-link { font-size: 0.58rem; padding: 6px 16px; letter-spacing: 0.1em; } }
  .subnav-link:hover {
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.7) !important;
  }
  .subnav-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.12);
    flex-shrink: 0;
  }
</style>

<section>
  <div class="video-section">
    <!-- Video backgrounds -->
    <div class="video-bg-wrap">
      <video class="video-bg-desktop" autoplay muted loop playsinline>
        <source src="/video-bg.mp4" type="video/mp4" />
      </video>
      <video class="video-bg-mobile" autoplay muted loop playsinline>
        <source src="/video-bg-mobile.mp4" type="video/mp4" />
      </video>
    </div>

    <div class="video-gradient"></div>

    <!-- Content -->
    <div class="video-content px-5 md:px-10 lg:px-16">
      <h2 class="video-headline">
        Helping you stop dancing inside, since 2016.
      </h2>
      <div class="silent-btns">
        {silentLinks.map((link) => (
          <a href={link.href} class="silent-btn">{link.label}</a>
        ))}
      </div>
    </div>
  </div>

  <!-- Secondary nav row -->
  <div class="video-subnav">
    <a href="/shop" class="subnav-link">Shop</a>
    <span class="subnav-dot"></span>
    <a href="/artists" class="subnav-link">Artists</a>
    <span class="subnav-dot"></span>
    <a href="/events" class="subnav-link">Events</a>
    <span class="subnav-dot"></span>
    <a href="/boog-vj" class="subnav-link">Boog.VJ</a>
    <span class="subnav-dot"></span>
    <a href="/immersive-structures" class="subnav-link">Installations</a>
    <span class="subnav-dot"></span>
    <a href="/blog" class="subnav-link">Blog</a>
    <span class="subnav-dot"></span>
    <a href="https://theboogiecollective.com/contact" class="subnav-link">Contact</a>
    <span class="subnav-dot"></span>
    <a href="https://billing.stripe.com/p/login/5kA4jQdGtb9m8N2fYY" target="_blank" rel="noopener" class="subnav-link">My Orders</a>
  </div>
</section>

