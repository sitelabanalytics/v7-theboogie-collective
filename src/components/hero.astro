---
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon";
import AudioReactiveOverlay from "@components/audio-reactive-overlay.astro";
---
<style>
  #heroSection {
    background-image: url('/hero-bg.webp');
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center;
    height: 640px;
    max-height: 640px;
    position: relative;
  }
  @media (max-width: 768px) {
    #heroSection {
      background-image: url('/hero-bg-mobile.webp');
    }
  }

  .hero-text {
    max-width: 900px;
    mix-blend-mode: difference;
    padding: 0 20px;
  }
  .hero-text h1 {
    font-size: 1.5rem;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #fff;
    word-break: keep-all;
  }
  @media (min-width: 480px) { .hero-text h1 { font-size: 2rem; } }
  @media (min-width: 768px) { .hero-text h1 { font-size: 3rem; } }
  @media (min-width: 1024px) { .hero-text h1 { font-size: 3.8rem; } }
  @media (min-width: 1280px) { .hero-text h1 { font-size: 4.5rem; } }

  .hero-sub {
    mix-blend-mode: normal;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5) !important;
    margin-top: 14px;
    max-width: 380px;
  }
</style>

<main class="">
  <div id="heroSection" class="mx-auto flex flex-col justify-start items-start relative">
    <AudioReactiveOverlay />
    <div class="hero-text px-5 md:px-10 lg:px-16 mt-24 md:mt-32" style="z-index: 2;">
      <h1 class="font-bold">
        Welcome to the&nbsp;&nbsp;<span style="font-family: 'idlewild';">Collective.</span>
      </h1>
      <p class="hero-sub">
        Australian music label for outdoor electronic DJ's and producers.
        Helping you stop dancing inside since 2016.
      </p>
    </div>
  </div>
</main>
