---
import ContainerSticky from "@components/container-sticky.astro";
import Link from "@components/ui/link.astro";
import Dropdown from "./dropdown.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";
import aidxnLogo from 'assets/tbc/tbc-immersive-logo-white.svg';


const menuitems = [
  {
    title: "Artists",
    path: "/artists",
  },
  {
    title: "Events",
    path: "/events",
  },
  {
    title: "Installations",
    path: "/immersive-structures",
  },
  {
    title: "Contact",
    path: "https://theboogiecollective.com/contact",
  },
];
---

<style>
  #navLogo {
    height: 75px;
    margin: 15px auto;
    transition: height 0.35s cubic-bezier(0.16, 1, 0.3, 1), margin 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  header.nav-scrolled #navLogo {
    height: 38px;
    margin: 8px auto;
  }
  @media only screen and (max-width: 968px) {
    #navLogo { height: 60px; }
    header.nav-scrolled #navLogo { height: 30px; margin: 6px auto; }
  }
  @media only screen and (max-width: 568px) {
    #navLogo { height: 50px; }
    header.nav-scrolled #navLogo { height: 25px; margin: 6px auto; }
  }

  header {
    background: rgba(0, 0, 0, 0.33);
    backdrop-filter: blur(15px);
    border: 0.5px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    transition: padding 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-motto {
    font-family: 'wotfard';
    font-size: 0.6rem;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.35) !important;
    letter-spacing: 0.02em;
    white-space: nowrap;
    transition: opacity 0.35s;
  }
  header.nav-scrolled .nav-motto { opacity: 0; }

  .nav-orders-link {
    font-family: 'inconsolata' !important;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.45) !important;
    transition: color 0.2s;
  }
  .nav-orders-link:hover { color: #fff !important; }
  header.nav-scrolled {
    padding-top: 2px;
    padding-bottom: 2px;
  }

  /* ─── Logo suspense splash ─── */
  .logo-suspense {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: suspenseFade 0.6s ease-in 1.4s forwards;
    pointer-events: all;
  }
  .logo-suspense img {
    width: 33vw;
    max-width: 400px;
    opacity: 0;
    transform: scale(0.92);
    animation: suspenseLogoIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }
  @media (max-width: 768px) {
    .logo-suspense img {
      width: 66vw;
      max-width: 320px;
    }
  }
  @keyframes suspenseLogoIn {
    from { opacity: 0; transform: scale(0.92); }
    to { opacity: 1; transform: scale(1); }
  }
  @keyframes suspenseFade {
    from { opacity: 1; pointer-events: all; }
    to { opacity: 0; pointer-events: none; }
  }
</style>

<!-- Logo suspense splash -->
<div class="logo-suspense" id="logoSuspense">
  <img src={aidxnLogo} alt="The Boogie Collective x Immersive Structures" />
</div>

<ContainerSticky>
  <header id="mainNav" class="m-2 border rounded-lg mx-auto flex flex-col lg:flex-row justify-between items-center mb-4 px-2 md:px-6 lg:px-8">
    <Astronav>
      <div class="flex w-full lg:w-auto items-center justify-between">
        <div class="flex items-center gap-3 md:gap-4">
          <a href="/">
            <img id="navLogo" src={aidxnLogo} alt="The Boogie Collective Logo"/>
          </a>
          <p class="nav-motto hidden sm:block">Helping you stop<br>dancing inside.</p>
        </div>
        <div class="block lg:hidden">
          <MenuIcon class="w-6 h-6 pr-2 text-white" />
        </div>
      </div>
      <MenuItems class="text-xs xl:text-sm hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
        <ul class="flex flex-col lg:flex-row lg:gap-4">
          {
            menuitems.map((item, index) => (
              <>
                {item.children && (
                  <Dropdown
                    title={item.title}
                    children={item.children}
                    lastItem={index === menuitems.length - 1}
                  />
                )}

                {!item.children && (
                  <li>
                    <a
                      href={item.path}
                      class="flex lg:px-3 py-2 text-black hover:text-gray-700"
                    >
                      <h5 style="color: #fff !important;">
                        {item.title}
                      </h5>
                    </a>
                  </li>
                )}
              </>
            ))
          }
        </ul>

        <div class="text-sm lg:hidden flex flex-col my-3 gap-3">
          <Link href="/shop" size="md" block>Shop</Link>
          <a href="https://billing.stripe.com/p/login/5kA4jQdGtb9m8N2fYY" target="_blank" rel="noopener" class="nav-orders-link text-center py-2">My Orders</a>
        </div>
      </MenuItems>
    </Astronav>
    <div>
      <div class="text-sm hidden lg:flex items-center gap-4">
        <a href="https://billing.stripe.com/p/login/5kA4jQdGtb9m8N2fYY" target="_blank" rel="noopener" class="nav-orders-link">My Orders</a>
        <Link href="/shop" size="md">Shop</Link>
      </div>
    </div>
  </header>
</ContainerSticky>

<script is:inline>
  (function() {
    // Scroll-shrink header
    var nav = document.getElementById('mainNav');
    var lastY = 0;
    var scrolled = false;

    function onScroll() {
      var y = window.scrollY;
      if (y > 60 && !scrolled) {
        nav.classList.add('nav-scrolled');
        scrolled = true;
      } else if (y <= 30 && scrolled) {
        nav.classList.remove('nav-scrolled');
        scrolled = false;
      }
      lastY = y;
    }

    window.addEventListener('scroll', onScroll, { passive: true });

    // Remove suspense after animation completes
    var suspense = document.getElementById('logoSuspense');
    if (suspense) {
      suspense.addEventListener('animationend', function(e) {
        if (e.animationName === 'suspenseFade') {
          suspense.remove();
        }
      });
    }
  })();
</script>
