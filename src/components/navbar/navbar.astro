---
import Link from "@components/ui/link.astro";
import AudioReactiveOverlay from "@components/audio-reactive-overlay.astro";
const headerLogo = '/tbc-header-logo-white.svg';
const headerLogoDark = '/tbc-header-logo.svg';
const suspenseLogo = '/tbc-suspense-logo-white.svg';
const suspenseLogoDark = '/tbc-suspense-logo.svg';

const navLinks = [
  { ref: '01', title: 'Shop', path: '/shop' },
  { ref: '02', title: 'Artists', path: '/artists' },
  { ref: '03', title: 'Events', path: '/events', children: [
    { title: 'Happiness Hill', path: '/blog/happiness-hill-festival' },
    { title: 'Rabbits Eat Lettuce', path: '/blog/rabbits-eat-lettuce' },
    { title: 'Rainbow Serpent', path: '/blog/rainbow-serpent-festival' },
    { title: 'Bohemian Beatfreaks', path: '/blog/bohemian-beatfreaks' },
    { title: 'Dragon Dreaming', path: '/blog/dragon-dreaming' },
  ]},
  { ref: '04', title: 'Services', path: '/immersive-structures', children: [
    { title: 'Boog.VJ — Projection Mapping', path: '/boog-vj' },
    { title: 'Immersive Structures — Build & Design', path: '/immersive-structures' },
    { title: 'Event Curation', path: '/events' },
    { title: 'Artist Bookings', path: '/artists' },
    { title: 'Merch & Apparel', path: '/shop' },
  ]},
  { ref: '05', title: 'Blog', path: '/blog', children: [
    { title: 'Happiness Hill Festival', path: '/blog/happiness-hill-festival' },
    { title: 'Rabbits Eat Lettuce 2026', path: '/blog/rabbits-eat-lettuce' },
    { title: 'Esoteric Festival', path: '/blog/esoteric-festival' },
    { title: 'Subsonic Music Festival', path: '/blog/subsonic-music-festival' },
  ]},
  { ref: '06', title: 'Contact', path: 'https://theboogiecollective.com/contact' },
];
---

<style>
  /* ─── Top bar ─── */
  .nav-header {
    background: rgba(0, 0, 0, 0.33);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);
    border: 0.5px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  }
  @media (prefers-color-scheme: light) {
    .nav-header {
      background: rgba(255, 255, 255, 0.6);
      border: 0.5px solid rgba(0, 0, 0, 0.08);
      box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
    }
    #navLogo { content: url('/tbc-header-logo.svg'); }
    .nav-motto { color: rgba(0, 0, 0, 0.4) !important; }
    .nav-icon-btn { color: rgba(0, 0, 0, 0.5); }
    .nav-icon-btn:hover { background: rgba(0, 0, 0, 0.06); color: #000; }
    .nav-toggle { color: #000; }
    .nav-toggle:hover { background: rgba(0, 0, 0, 0.06); }
    .nav-secondary { background: rgba(255, 255, 255, 0.4); border-color: rgba(0, 0, 0, 0.04); }
    .nav-sec-link { color: rgba(0, 0, 0, 0.45) !important; }
    .nav-sec-link:hover { color: rgba(0, 0, 0, 0.8) !important; }
  }
  #navBar {
    transition: padding 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #navBar.nav-scrolled { padding-top: 4px; padding-bottom: 4px; }

  #navLogo {
    height: 49px;
    margin: 8px 0;
    transition: height 0.35s cubic-bezier(0.16, 1, 0.3, 1), margin 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #navBar.nav-scrolled #navLogo { height: 24px; margin: 5px 0; }
  @media (max-width: 768px) {
    #navLogo { height: 38px; }
    #navBar.nav-scrolled #navLogo { height: 20px; }
  }

  .nav-motto {
    font-family: 'wotfard';
    font-size: 0.58rem;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.3) !important;
    letter-spacing: 0.02em;
    white-space: nowrap;
    transition: opacity 0.35s;
  }
  #navBar.nav-scrolled .nav-motto { opacity: 0; pointer-events: none; }

  /* ─── Hamburger button ─── */
  .nav-toggle {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
    color: #fff;
  }
  .nav-toggle:hover { background: rgba(255,255,255,0.08); }
  .nav-toggle svg { width: 22px; height: 22px; fill: currentColor; }

  /* ─── Full overlay menu ─── */
  .nav-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(0, 0, 0, 0.96);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nav-overlay.open {
    opacity: 1;
    pointer-events: all;
  }

  .nav-overlay-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 20px;
  }
  @media (min-width: 768px) { .nav-overlay-top { padding: 16px 40px; } }
  @media (min-width: 1024px) { .nav-overlay-top { padding: 16px 64px; } }

  .nav-overlay-body {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr;
    padding: 0 20px 40px;
    overflow-y: auto;
  }
  @media (min-width: 1024px) {
    .nav-overlay-body {
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      padding: 0 64px 60px;
    }
  }

  /* Left panel — description (desktop only) */
  .nav-panel {
    display: none;
    align-items: center;
    justify-content: center;
    padding: 40px;
    border-radius: 20px;
    background: rgba(255,255,255,0.03);
    border: 0.5px solid rgba(255,255,255,0.06);
  }
  @media (min-width: 1024px) { .nav-panel { display: flex; } }
  .nav-panel p {
    font-size: 1.15rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.5) !important;
    max-width: 360px;
  }
  .nav-panel strong {
    color: rgba(255,255,255,0.8) !important;
    font-weight: 500;
  }

  /* Right panel — links */
  .nav-links {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 0;
    transition: opacity 0.2s;
    text-decoration: none;
  }
  @media (min-width: 768px) { .nav-link { padding: 28px 0; } }

  .nav-link:hover { opacity: 0.7; }

  .nav-link-group {
    border-bottom: 1px solid rgba(255,255,255,0.06);
    opacity: 0;
    transform: translateY(12px);
  }
  .nav-overlay.open .nav-link-group {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1), transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Dropdown sub-links */
  .nav-dropdown {
    display: flex;
    flex-wrap: wrap;
    gap: 4px 8px;
    padding: 0 0 16px 32px;
  }
  @media (min-width: 768px) {
    .nav-dropdown { padding: 0 0 20px 40px; gap: 6px 12px; }
  }
  .nav-dropdown-link {
    font-family: 'wotfard' !important;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.35) !important;
    text-decoration: none;
    padding: 4px 12px;
    border-radius: 6px;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .nav-dropdown-link:hover {
    color: rgba(255, 255, 255, 0.8) !important;
    background: rgba(255, 255, 255, 0.05);
  }

  .nav-link-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .nav-link-ref {
    font-family: 'inconsolata' !important;
    font-size: 0.65rem;
    color: rgba(255,255,255,0.3) !important;
    letter-spacing: 0.05em;
  }
  .nav-link-title {
    font-size: 1.8rem;
    font-weight: 500;
    letter-spacing: -0.02em;
  }
  @media (min-width: 768px) { .nav-link-title { font-size: 2.4rem; } }

  .nav-link-arrow {
    width: 20px;
    height: 20px;
    fill: rgba(255,255,255,0.3);
    flex-shrink: 0;
  }
  @media (min-width: 768px) { .nav-link-arrow { width: 24px; height: 24px; } }

  /* Bottom bar in overlay */
  .nav-overlay-bottom {
    padding: 0 20px 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  @media (min-width: 768px) { .nav-overlay-bottom { padding: 0 40px 36px; } }
  @media (min-width: 1024px) { .nav-overlay-bottom { padding: 0 64px 40px; } }

  .nav-bottom-link {
    font-family: 'inconsolata' !important;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.35) !important;
    transition: color 0.2s;
    text-decoration: none;
  }
  .nav-bottom-link:hover { color: #fff !important; }

  /* ─── Icon buttons (notifications, account) ─── */
  .nav-icon-btn {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.45);
    transition: all 0.2s;
    text-decoration: none;
  }
  .nav-icon-btn:hover {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
  }
  .nav-icon-btn svg {
    width: 18px;
    height: 18px;
  }
  @media (min-width: 768px) {
    .nav-icon-btn { width: 42px; height: 42px; }
    .nav-icon-btn svg { width: 20px; height: 20px; }
  }

  /* ─── Secondary nav row ─── */
  .nav-secondary {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0 4px;
    margin: 0 2px;
    border-radius: 0 0 8px 8px;
    background: rgba(0, 0, 0, 0.2);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 0.5px solid rgba(255, 255, 255, 0.04);
    border-top: none;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    transition: all 0.3s;
  }
  @media (min-width: 768px) {
    .nav-secondary { padding: 0 12px; }
  }
  .nav-secondary::-webkit-scrollbar { display: none; }

  .nav-sec-link {
    display: inline-flex;
    align-items: center;
    padding: 6px 8px;
    font-family: 'wotfard' !important;
    font-size: 0.52rem;
    color: rgba(255, 255, 255, 0.35) !important;
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  @media (min-width: 480px) { .nav-sec-link { font-size: 0.58rem; padding: 6px 10px; } }
  @media (min-width: 768px) { .nav-sec-link { font-size: 0.68rem; padding: 7px 12px; } }
  .nav-sec-link:hover { color: rgba(255, 255, 255, 0.7) !important; }

  .nav-secondary.nav-sec-hidden { opacity: 0; pointer-events: none; height: 0; padding: 0; overflow: hidden; }

  /* ─── Logo suspense splash ─── */
  .logo-suspense {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: suspenseFade 0.6s ease-in 1.4s forwards;
    pointer-events: all;
  }
  .logo-suspense > img:last-of-type {
    width: 33vw;
    max-width: 400px;
    opacity: 0;
    transform: scale(0.92);
    animation: suspenseLogoIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }
  @media (max-width: 768px) {
    .logo-suspense > img:last-of-type { width: 66vw; max-width: 320px; }
  }

  .suspense-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: 0;
    opacity: 0.35;
  }
  .suspense-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(ellipse at center, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.85) 70%);
  }
  @keyframes suspenseLogoIn {
    from { opacity: 0; transform: scale(0.92); }
    to { opacity: 1; transform: scale(1); }
  }
  @keyframes suspenseFade {
    from { opacity: 1; pointer-events: all; }
    to { opacity: 0; pointer-events: none; }
  }
</style>

<!-- Logo suspense splash -->
<div class="logo-suspense" id="logoSuspense">
  <img class="suspense-bg" id="suspenseBg" src="" alt="" />
  <div class="suspense-gradient"></div>
  <AudioReactiveOverlay />
  <img src={suspenseLogo} alt="The Boogie Collective" style="position: relative; z-index: 3;" />
</div>

<!-- Top bar -->
<div class="w-full px-2 top-2 sticky z-50">
  <header id="navBar" class="nav-header m-2 rounded-lg mx-auto flex items-center justify-between px-4 md:px-6 lg:px-8">
    <!-- Left: logo + motto -->
    <div class="flex items-center gap-3 md:gap-4">
      <a href="/">
        <img id="navLogo" src={headerLogo} alt="The Boogie Collective Logo"/>
      </a>
      <p class="nav-motto hidden sm:block">Helping you stop<br>dancing inside.</p>
    </div>

    <!-- Right: actions -->
    <div class="flex items-center gap-1 md:gap-2">
      <!-- Notifications -->
      <a href="/blog" class="nav-icon-btn" aria-label="Notifications" title="Updates">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M20 17H22V19H2V17H4V10C4 5.58172 7.58172 2 12 2C16.4183 2 20 5.58172 20 10V17ZM18 17V10C18 6.68629 15.3137 4 12 4C8.68629 4 6 6.68629 6 10V17H18ZM9 21H15V23H9V21Z"/></svg>
      </a>
      <!-- Account / My Orders -->
      <a href="https://billing.stripe.com/p/login/5kA4jQdGtb9m8N2fYY" target="_blank" rel="noopener" class="nav-icon-btn" aria-label="My Account" title="My Orders">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M4 22C4 17.5817 7.58172 14 12 14C16.4183 14 20 17.5817 20 22H18C18 18.6863 15.3137 16 12 16C8.68629 16 6 18.6863 6 22H4ZM12 13C8.685 13 6 10.315 6 7C6 3.685 8.685 1 12 1C15.315 1 18 3.685 18 7C18 10.315 15.315 13 12 13ZM12 11C14.21 11 16 9.21 16 7C16 4.79 14.21 3 12 3C9.79 3 8 4.79 8 7C8 9.21 9.79 11 12 11Z"/></svg>
      </a>
      <!-- Menu -->
      <button class="nav-toggle" id="navMenuBtn" aria-label="Open menu">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M19 8H5V10H19V8ZM19 14H5V16H19V14Z"/></svg>
      </button>
    </div>
  </header>
  <div class="nav-secondary" id="navSecondary">
    <a href="/about" class="nav-sec-link">About</a>
    <a href="/artists" class="nav-sec-link">Artists</a>
    <a href="/events" class="nav-sec-link">Events</a>
    <a href="/immersive-structures" class="nav-sec-link">Installations</a>
    <a href="/boog-vj" class="nav-sec-link">Projection</a>
    <a href="/blog" class="nav-sec-link">Blog</a>
    <a href="/shop" class="nav-sec-link">Shop</a>
    <a href="https://theboogiecollective.com/contact" class="nav-sec-link">Contact</a>
  </div>
</div>

<!-- Full overlay menu -->
<div class="nav-overlay" id="navOverlay">
  <!-- Top bar (mirror) -->
  <div class="nav-overlay-top">
    <a href="/">
      <img src={headerLogo} alt="The Boogie Collective" style="height: 50px;"/>
    </a>
    <button class="nav-toggle" id="navCloseBtn" aria-label="Close menu">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12.0007 10.5865L16.9504 5.63672L18.3646 7.05093L13.4149 12.0007L18.3646 16.9504L16.9504 18.3646L12.0007 13.4149L7.05093 18.3646L5.63672 16.9504L10.5865 12.0007L5.63672 7.05093L7.05093 5.63672L12.0007 10.5865Z"/></svg>
    </button>
  </div>

  <!-- Body -->
  <div class="nav-overlay-body">
    <!-- Left: info panel (desktop) -->
    <div class="nav-panel">
      <p>
        <strong>The Boogie Collective</strong> is an Australian outdoor electronic music label. We curate events, book artists, design immersive stage installations, and produce limited release merch — helping you stop dancing inside since 2016.
      </p>
    </div>

    <!-- Right: navigation links -->
    <nav class="nav-links">
      {navLinks.map((link, i) => (
        <div class="nav-link-group" style={`transition-delay: ${0.05 + i * 0.05}s`}>
          <a href={link.path} class="nav-link">
            <div class="nav-link-left">
              <span class="nav-link-ref">{link.ref}</span>
              <h4 class="nav-link-title">{link.title}</h4>
            </div>
            <svg class="nav-link-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z"/></svg>
          </a>
          {link.children && (
            <div class="nav-dropdown">
              {link.children.map((child) => (
                <a href={child.path} class="nav-dropdown-link">{child.title}</a>
              ))}
            </div>
          )}
        </div>
      ))}
    </nav>
  </div>

  <!-- Bottom bar -->
  <div class="nav-overlay-bottom">
    <div class="flex gap-6">
      <a href="https://billing.stripe.com/p/login/5kA4jQdGtb9m8N2fYY" target="_blank" rel="noopener" class="nav-bottom-link">My Orders</a>
      <a href="https://instagram.com/theboogiecollective/" target="_blank" rel="noopener" class="nav-bottom-link">Instagram</a>
      <a href="https://instagram.com/boog.vj/" target="_blank" rel="noopener" class="nav-bottom-link">@boog.vj</a>
      <a href="https://facebook.com/theboogiecollective/" target="_blank" rel="noopener" class="nav-bottom-link">Facebook</a>
    </div>
    <p class="nav-bottom-link" style="cursor: default;">&copy; {new Date().getFullYear()} The Boogie Collective</p>
  </div>
</div>

<script is:inline>
  (function() {
    var navBar = document.getElementById('navBar');
    var overlay = document.getElementById('navOverlay');
    var openBtn = document.getElementById('navMenuBtn');
    var closeBtn = document.getElementById('navCloseBtn');

    // Open/close menu
    function openMenu() {
      overlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    }
    function closeMenu() {
      overlay.classList.remove('open');
      document.body.style.overflow = '';
    }
    openBtn.addEventListener('click', openMenu);
    closeBtn.addEventListener('click', closeMenu);
    // Close on link click
    var links = overlay.querySelectorAll('.nav-link, .nav-dropdown-link, .nav-bottom-link');
    for (var i = 0; i < links.length; i++) {
      links[i].addEventListener('click', closeMenu);
    }
    // Safety: ensure scroll is never permanently locked
    document.body.style.overflow = '';
    window.addEventListener('pageshow', function() { document.body.style.overflow = ''; });

    // Scroll-shrink header + secondary row — expands on 50px scroll-up
    var secondary = document.getElementById('navSecondary');
    var scrolled = false;
    var lastY = window.scrollY;
    var highY = 0;
    window.addEventListener('scroll', function() {
      var y = window.scrollY;
      if (y > lastY) { highY = y; } // track highest scroll point
      if (y > 80 && !scrolled) {
        navBar.classList.add('nav-scrolled');
        if (secondary) secondary.classList.add('nav-sec-hidden');
        scrolled = true;
      } else if (scrolled && (y <= 20 || (highY - y) > 50)) {
        navBar.classList.remove('nav-scrolled');
        if (secondary) secondary.classList.remove('nav-sec-hidden');
        scrolled = false;
        highY = y;
      }
      lastY = y;
    }, { passive: true });

    // Suspense — random event background + cleanup
    var suspense = document.getElementById('logoSuspense');
    var suspenseBg = document.getElementById('suspenseBg');
    if (suspenseBg) {
      var eventImages = ['/event-1.jpg', '/event-2.webp', '/event-3.jpg', '/event-4.jpg', '/event-5.jpg', '/event-6.jpg'];
      suspenseBg.src = eventImages[Math.floor(Math.random() * eventImages.length)];
    }
    if (suspense) {
      suspense.addEventListener('animationend', function(e) {
        if (e.animationName === 'suspenseFade') {
          suspense.remove();
        }
      });
    }
  })();
</script>
