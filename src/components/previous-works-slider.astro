---
const events = [
  {
    title: "Happiness Hill 2",
    category: "Event Curation",
    description: "Three-day outdoor electronic music festival in Jimna, QLD. Full production — stage, lighting, lineup, and site build.",
    image: "/event-1.jpg",
    link: "/events",
  },
  {
    title: "Happiness Hill",
    category: "Event Curation",
    description: "The original Happiness Hill. Concept to execution outdoor festival in the QLD hinterland.",
    image: "/event-3.jpg",
    link: "/events",
  },
  {
    title: "Bohemian Beatfreaks 2018",
    category: "Stage Build",
    description: "Custom bamboo stage design and build for Bohemian Beatfreaks festival.",
    image: "/event-6.jpg",
    link: "/immersive-structures",
  },
  {
    title: "Rabbits Eat Lettuce 2019",
    category: "Stage Build",
    description: "Immersive stage structures and UV installations for Rabbits Eat Lettuce festival.",
    image: "/event-5.jpg",
    link: "/immersive-structures",
  },
  {
    title: "Dirty Disco",
    category: "Event Curation",
    description: "Single-night warehouse electronic events in Brisbane and the Sunshine Coast.",
    image: "/event-4.jpg",
    link: "/events",
  },
];
---

<style is:global>
  .works-cell {
    margin-right: 14px;
    width: 80vw;
    max-width: 400px;
    height: 320px;
    border-radius: 14px;
    overflow: hidden;
    position: relative;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s;
    border: 0.5px solid rgba(255, 255, 255, 0.08);
  }
  .works-cell:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.2);
  }
  @media (min-width: 520px) { .works-cell { width: 55vw; max-width: 420px; } }
  @media (min-width: 768px) { .works-cell { width: 42vw; max-width: 440px; height: 360px; } }
  @media (min-width: 1024px) { .works-cell { width: 32vw; max-width: 480px; margin-right: 16px; } }

  .works-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .works-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .works-cell:hover .works-bg img { transform: scale(1.05); }

  .works-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(0deg, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.5) 45%, rgba(0,0,0,0.15) 100%);
    pointer-events: none;
  }

  .works-content {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    z-index: 2;
    padding: 24px;
  }
  .works-label {
    font-family: 'inconsolata' !important;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.4) !important;
    margin-bottom: 6px;
  }
  .works-title {
    font-size: 1.3rem;
    margin-bottom: 8px;
    color: #fff !important;
  }
  @media (min-width: 768px) { .works-title { font-size: 1.5rem; } }
  .works-desc {
    font-size: 0.78rem;
    line-height: 1.55;
    color: rgba(255,255,255,0.5) !important;
    max-width: 340px;
  }

  .works-carousel { max-width: 100vw !important; overflow: hidden; }
  .works-carousel .flickity-viewport { min-height: 1px; overflow: visible; }
</style>

<section class="py-12" style="background: #000;">
  <div class="px-5 md:px-10 lg:px-16 mb-8 flex flex-row items-end justify-between">
    <div>
      <h5 class="text-xs md:text-sm">Previous Work</h5>
      <h4 class="text-2xl md:text-3xl lg:text-4xl my-2 font-bold lg:tracking-tight">
        Event Portfolio.
      </h4>
    </div>
    <a href="/contact" class="rounded text-center transition px-5 py-2 text-sm border border-white/20 hover:border-white/50 text-white mb-2">
      Contact
    </a>
  </div>

  <div class="works-carousel pl-5 md:pl-10 lg:pl-16">
    {events.map((evt) => (
      <a href={evt.link} class="works-cell">
        <div class="works-bg">
          <img src={evt.image} alt={evt.title} loading="lazy" />
        </div>
        <div class="works-gradient"></div>
        <div class="works-content">
          <p class="works-label">{evt.category}</p>
          <h3 class="works-title">{evt.title}</h3>
          <p class="works-desc">{evt.description}</p>
        </div>
      </a>
    ))}
  </div>
</section>

<script is:inline>
  var worksFlkty = new Flickity('.works-carousel', {
    cellAlign: 'left',
    contain: true,
    prevNextButtons: false,
    pageDots: true,
    freeScroll: true,
    imagesLoaded: true
  });
</script>
