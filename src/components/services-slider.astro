  {
    title: "Event Curation",
    description: "Full event production from concept to execution. Lineup curation, venue selection, and on-the-ground management for outdoor electronic events.",
    image: "/event-1.jpg",
    link: "/events",
  },
  {
    title: "Stage Design",
    description: "3D stage design and bamboo construction across 50+ events on the Eastern Australian Coast. Custom immersive structures for any scale.",
    image: "/event-6.jpg",
    link: "/immersive-structures",
  },
  {
    title: "Projection Mapping",
    description: "Large-scale projection mapping on stages, natural formations, and custom-built structures. Reactive visuals synced to live audio.",
    image: "/event-2.webp",
    link: "/boog-vj",
  },
  {
    title: "UV Art Installations",
    description: "UV reactive painted elements and blacklight installations that transform spaces after dark. Custom art for festival zones and stages.",
    image: "/event-5.jpg",
    link: "/boog-vj",
  },
  {
    title: "Artist Bookings",
    description: "Local and nationally touring artists across the eastern Australian coast. Techno, psytrance, breaks, DnB, and progressive.",
    image: "/event-3.jpg",
    link: "/artists",
  },
  {
    title: "Lighting Design",
    description: "Specialist lighting rigs for outdoor stages and festival environments. Laser, LED, and traditional stage lighting design.",
    image: "/event-4.jpg",
    link: "/immersive-structures",
  },
  {
    title: "Shade Installations",
    description: "Rigging and shade sail installations for outdoor events and festivals. Custom coverage for any site.",
    image: "/event-shade-install.jpg",
    link: "/immersive-structures",
  },
  {
    title: "Laser Shows",
    description: "High-powered laser show production for festivals, stages, and outdoor events. Full rig supply and operation.",
    image: "/event-laser-show.jpg",
    link: "/boog-vj",
  },
  {
    title: "Festoon Lighting Hire",
    description: "Corporate and event festoon lighting hire and installation. Outdoor lagoon, garden, and venue setups.",
    image: "/event-festoon.jpg",
    link: "/immersive-structures",
  },
  {
    title: "Creative Festoon",
    description: "Creative festoon installation and hire for unique venues. Custom layouts for marinas, gardens, and architectural spaces.",
    image: "/event-festoon-marina.webp",
    link: "/immersive-structures",
  },
  {
    title: "DMX Lighting",
    description: "Professional DMX lighting operation for live bands, stages, and events. Full rig programming and operation.",
    image: "/event-dmx-lighting.jpg",
    link: "/immersive-structures",
  },
];
---

<style is:global>
  .svc-cell {
    margin-right: 14px;
    width: 80vw;
    max-width: 400px;
    height: 320px;
    border-radius: 14px;
    overflow: hidden;
    position: relative;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s;
    border: 0.5px solid rgba(255, 255, 255, 0.08);
  }
  .svc-cell:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.2);
  }
  @media (min-width: 520px) { .svc-cell { width: 55vw; max-width: 420px; } }
  @media (min-width: 768px) { .svc-cell { width: 42vw; max-width: 440px; height: 360px; } }
  @media (min-width: 1024px) { .svc-cell { width: 32vw; max-width: 480px; margin-right: 16px; } }

  .svc-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .svc-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .svc-cell:hover .svc-bg img { transform: scale(1.05); }

  .svc-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(0deg, rgba(0,0,0,0.92) 0%, rgba(0,0,0,0.5) 45%, rgba(0,0,0,0.15) 100%);
    pointer-events: none;
  }

  .svc-content {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    z-index: 2;
    padding: 24px;
  }
  .svc-label {
    font-family: 'inconsolata' !important;
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.4) !important;
    margin-bottom: 6px;
  }
  .svc-title {
    font-size: 1.3rem;
    margin-bottom: 8px;
    color: #fff !important;
  }
  @media (min-width: 768px) { .svc-title { font-size: 1.5rem; } }
  .svc-desc {
    font-size: 0.78rem;
    line-height: 1.55;
    color: rgba(255,255,255,0.5) !important;
    max-width: 340px;
  }

  .svc-carousel { max-width: 100vw !important; overflow: hidden; }
  .svc-carousel .flickity-viewport { min-height: 1px; overflow: visible; }
</style>

<section class="py-12" style="background: #000;">
  <div class="px-5 md:px-10 lg:px-16 mb-8 flex flex-row items-end justify-between">
    <div>
      <h5 class="text-xs md:text-sm">What We Do</h5>
      <h4 class="text-2xl md:text-3xl lg:text-4xl my-2 font-bold lg:tracking-tight">
        Services.
      </h4>
    </div>
    <a href="https://theboogiecollective.com/contact" class="rounded text-center transition px-5 py-2 text-sm border border-white/20 hover:border-white/50 text-white mb-2">
      Enquire
    </a>
  </div>

  <div class="svc-carousel pl-5 md:pl-10 lg:pl-16">
    {services.map((svc) => (
      <a href={svc.link} class="svc-cell">
        <div class="svc-bg">
          <img src={svc.image} alt={svc.title} loading="lazy" />
        </div>
        <div class="svc-gradient"></div>
        <div class="svc-content">
          <p class="svc-label">Services</p>
          <h3 class="svc-title">{svc.title}</h3>
          <p class="svc-desc">{svc.description}</p>
        </div>
      </a>
    ))}
  </div>
</section>

<script is:inline>
  var svcFlkty = new Flickity('.svc-carousel', {
    cellAlign: 'left',
    contain: true,
    prevNextButtons: false,
    pageDots: true,
    freeScroll: true,
    imagesLoaded: true
  });
</script>
