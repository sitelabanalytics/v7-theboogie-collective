  {
    name: "Classic Oversized Tee",
    colorway: "Purple Ink on Black",
    code: "5069 AS",
    fit: "Men's Oversized",
    weight: "220 GSM · 100% Combed Cotton",
    sizes: ["M", "L", "XL"],
    swatch: "#6B00CC",
    image: "/slider-shirts/tbc-shirt-slider5.webp",
    stripe: "https://buy.stripe.com/fZe02camE7hxgXmdQR",
  },
  {
    name: "Classic Oversized Tee",
    colorway: "Orange Ink on Black",
    code: "5069 AS",
    fit: "Men's Oversized",
    weight: "220 GSM · 100% Combed Cotton",
    sizes: ["M", "L", "XL"],
    swatch: "#FF6611",
    image: "/shop/tee-black-front.jpg",
    stripe: "https://buy.stripe.com/fZe02camE7hxgXmdQR",
  },
  {
    name: "Classic Oversized Tee",
    colorway: "White Stitch on Black",
    code: "5069 AS",
    fit: "Men's Oversized · Premium",
    weight: "220 GSM · 100% Combed Cotton",
    sizes: ["L"],
    swatch: "#FFFFFF",
    image: "/shop/tee-black-front.jpg",
    badge: "Limited",
    stripe: "https://buy.stripe.com/fZe02camE7hxgXmdQR",
  },
  {
    name: "Women's Crop Tee",
    colorway: "Purple Ink on Black",
    code: "4072 AS",
    fit: "Women's Cropped",
    weight: "220 GSM · 100% Combed Cotton",
    sizes: ["S"],
    swatch: "#6B00CC",
    image: "/shop/crop-black-front.webp",
    stripe: "https://buy.stripe.com/fZe02camE7hxgXmdQR",
  },
  {
    name: "Women's Crop Tee",
    colorway: "Orange Ink on Black",
    code: "4072 AS",
    fit: "Women's Cropped",
    weight: "220 GSM · 100% Combed Cotton",
    sizes: ["S"],
    swatch: "#FF6611",
    image: "/shop/crop-black-front.webp",
    stripe: "https://buy.stripe.com/fZe02camE7hxgXmdQR",
  },
  {
    name: "Women's Crop Tee",
    colorway: "Purple Ink on Orchid",
    code: "4072 AS",
    fit: "Women's Cropped",
    weight: "220 GSM · 100% Combed Cotton",
    sizes: ["S"],
    swatch: "#6B00CC",
    swatchBg: "#DA70D6",
    image: "/shop/crop-black-front.webp",
    stripe: "https://buy.stripe.com/fZe02camE7hxgXmdQR",
  },
];

const jumpers = [
  {
    name: "Box Hood",
    colorway: "Purple Ink on Black",
    code: "5171 AS",
    fit: "Unisex Relaxed",
    weight: "350 GSM · Anti-Pill CVC Fleece",
    sizes: ["M", "L"],
    swatch: "#6B00CC",
    image: "/shop/hood-black-front.webp",
    stripe: "https://buy.stripe.com/fZe02camE7hxgXmdQR",
  },
  {
    name: "Box Hood",
    colorway: "Orange Ink on Black",
    code: "5171 AS",
    fit: "Unisex Relaxed",
    weight: "350 GSM · Anti-Pill CVC Fleece",
    sizes: ["M", "L"],
    swatch: "#FF6611",
    image: "/shop/hood-black-front.webp",
    stripe: "https://buy.stripe.com/fZe02camE7hxgXmdQR",
  },
  {
    name: "Box Hood",
    colorway: "Premium White Stitch on Black",
    code: "5171 AS",
    fit: "Unisex Relaxed · Premium",
    weight: "350 GSM · Anti-Pill CVC Fleece",
    sizes: ["M", "L"],
    swatch: "#FFFFFF",
