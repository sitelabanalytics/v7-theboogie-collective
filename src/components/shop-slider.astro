---
import { products } from "../data/products.js";

// Pick featured variants for homepage slider — mix of products, fits, and colors
const sliderItems = [];
for (const product of products) {
  const seen = new Set();
  for (const v of product.variants) {
    if (seen.has(v.colorKey)) continue;
    seen.add(v.colorKey);
    sliderItems.push({ slug: product.slug, name: product.name, ...v });
    if (seen.size >= 3) break;
  }
}
---

<!-- CSS -->
<link rel="stylesheet" href="https://unpkg.com/flickity@2/dist/flickity.min.css">
<!-- JavaScript -->
<script is:inline src="https://unpkg.com/flickity@2/dist/flickity.pkgd.min.js"></script>

<style is:global>
  .shop-slider-cell {
    margin-right: 10px;
    width: 66vw;
    max-width: 260px;
    border-radius: 12px;
    overflow: hidden;
    background: linear-gradient(165deg, rgba(2, 0, 36, 0.5) 0%, rgba(9, 9, 121, 0.15) 65%, rgba(0, 213, 255, 0.08) 100%);
    border: 0.5px solid rgba(255, 255, 255, 0.08);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s;
  }
  .shop-slider-cell:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.15);
  }
  /* Small phones */
  @media (min-width: 400px) {
    .shop-slider-cell { width: 58vw; max-width: 260px; }
  }
  /* Large phones */
  @media (min-width: 520px) {
    .shop-slider-cell { width: 44vw; max-width: 280px; margin-right: 12px; }
  }
  /* Tablets */
  @media (min-width: 768px) {
    .shop-slider-cell { width: 36vw; max-width: 300px; }
  }
  /* Small desktops */
  @media (min-width: 1024px) {
    .shop-slider-cell { width: 26vw; max-width: 320px; margin-right: 16px; }
  }
  /* Large desktops */
  @media (min-width: 1280px) {
    .shop-slider-cell { width: 22vw; max-width: 340px; }
  }

  .shop-slider-cell-img {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #111;
    position: relative;
  }
  .shop-slider-cell-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .shop-slider-cell:hover .shop-slider-cell-img img {
    transform: scale(1.05);
  }
  .shop-slider-cell-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    font-family: 'inconsolata';
    text-transform: uppercase;
    font-size: 0.55rem;
    letter-spacing: 0.15em;
    padding: 3px 7px;
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(12px);
    border: 0.5px solid rgba(255, 255, 255, 0.2);
    border-radius: 4px;
    color: #fff;
  }
  @media (min-width: 768px) {
    .shop-slider-cell-badge {
      top: 10px;
      right: 10px;
      font-size: 0.6rem;
      padding: 3px 8px;
    }
  }
  .shop-slider-cell-swatch {
    position: absolute;
    bottom: 8px;
    left: 8px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.4);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }
  @media (min-width: 768px) {
    .shop-slider-cell-swatch {
      bottom: 10px;
      left: 10px;
      width: 14px;
      height: 14px;
    }
  }

  .shop-slider-cell-body {
    padding: 12px;
  }
  @media (min-width: 768px) {
    .shop-slider-cell-body { padding: 16px; }
  }
  .shop-slider-cell-colorway {
    font-family: 'inconsolata' !important;
    text-transform: uppercase;
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.45) !important;
    margin-bottom: 2px;
  }
  @media (min-width: 768px) {
    .shop-slider-cell-colorway { font-size: 0.65rem; }
  }
  .shop-slider-cell-name {
    font-size: 0.95rem;
    margin-bottom: 3px;
  }
  @media (min-width: 768px) {
    .shop-slider-cell-name { font-size: 1.1rem; margin-bottom: 4px; }
  }
  .shop-slider-cell-meta {
    font-size: 0.68rem;
    color: rgba(255, 255, 255, 0.35) !important;
    margin-bottom: 10px;
  }
  @media (min-width: 768px) {
    .shop-slider-cell-meta { font-size: 0.75rem; margin-bottom: 12px; }
  }
  .shop-slider-cell-btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 7px 12px;
    border-radius: 6px;
    font-family: 'inconsolata' !important;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.65rem;
    background: linear-gradient(135deg, #6B00CC, #FF6611);
    color: #fff !important;
    transition: opacity 0.2s;
  }
  @media (min-width: 768px) {
    .shop-slider-cell-btn { padding: 8px 16px; font-size: 0.7rem; }
  }
  .shop-slider-cell-btn:hover { opacity: 0.9; }

  /* Flickity overrides for shop slider */
  .shop-carousel {
    max-width: 100vw !important;
    overflow: hidden;
  }
  .shop-carousel .flickity-viewport {
    min-height: 1px;
    overflow: visible;
  }
</style>

<section id="shop-preview" class="py-12" style="background: #000;">
  <div class="px-5 md:px-10 lg:px-16 mb-8 flex flex-row items-end justify-between">
    <div>
      <h5 class="text-xs md:text-sm">Shop</h5>
      <h4 class="text-2xl md:text-3xl lg:text-4xl my-2 font-bold lg:tracking-tight">
        The Collection.
      </h4>
    </div>
    <a href="/shop" class="rounded text-center transition px-5 py-2 text-sm border border-white/20 hover:border-white/50 text-white mb-2">
      View All
    </a>
  </div>

  <div class="shop-carousel pl-5 md:pl-10 lg:pl-16">
    {sliderItems.map((item) => (
      <a href={`/shop/${item.slug}`} class="shop-slider-cell">
        <div class="shop-slider-cell-img">
          <img src={item.image} alt={`${item.name} — ${item.colorway}`} loading="lazy" />
          {item.badge && <span class="shop-slider-cell-badge">{item.badge}</span>}
          <span class="shop-slider-cell-swatch" style={`background: ${item.swatch}`}></span>
        </div>
        <div class="shop-slider-cell-body">
          <p class="shop-slider-cell-colorway">{item.colorway}</p>
          <h4 class="shop-slider-cell-name">{item.name}</h4>
          <p class="shop-slider-cell-meta">{item.fit} · {item.code}</p>
          <span class="shop-slider-cell-btn">Pre-Order Now</span>
        </div>
      </a>
    ))}
  </div>
</section>

<script is:inline>
  var shopFlkty = new Flickity('.shop-carousel', {
    cellAlign: 'left',
    contain: true,
    prevNextButtons: false,
    pageDots: true,
    freeScroll: true,
    imagesLoaded: true
  });
</script>
