---
import { products } from "../data/products.js";

// One slide per product with two images from different variants
const slides = products.map(product => {
  const defaultV = product.variants[0];
  const secondV = product.variants[1] || defaultV;
  const uniqueColors = [];
  const seen = new Set();
  product.variants.forEach(v => {
    if (!seen.has(v.colorKey)) {
      seen.add(v.colorKey);
      uniqueColors.push(v);
    }
  });
  const fits = [...new Set(product.variants.map(v => v.fit))];
  return {
    slug: product.slug,
    name: product.name,
    nextDrop: product.nextDrop || false,
    img1: defaultV.image,
    img2: defaultV.images[1] || defaultV.image,
    colorway: defaultV.colorway,
    fit: fits.join(' · '),
    code: defaultV.code,
    swatches: uniqueColors.map(v => v.swatch),
  };
});
---

<link rel="stylesheet" href="https://unpkg.com/flickity@2/dist/flickity.min.css">
<script is:inline src="https://unpkg.com/flickity@2/dist/flickity.pkgd.min.js"></script>

<style is:global>
  .shop-fs-carousel {
    max-width: 100vw !important;
    height: 640px;
    overflow: hidden;
  }
  @media (max-width: 768px) {
    .shop-fs-carousel { height: 580px; }
  }
  .shop-fs-carousel .flickity-viewport {
    height: 100% !important;
  }

  .shop-fs-cell {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
    background: #000;
  }

  /* ─── Dual image layout ─── */
  .shop-fs-images {
    display: flex;
    flex-direction: row;
    height: 100%;
    width: 100%;
  }
  @media (max-width: 768px) {
    .shop-fs-images { height: 100%; }
  }

  .shop-fs-img {
    flex: 1;
    overflow: hidden;
    position: relative;
    min-height: 0;
  }
  .shop-fs-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }
  .shop-fs-img:nth-child(2) { display: block; }
  @media (max-width: 768px) {
    .shop-fs-img:nth-child(2) { display: none; }
    .shop-fs-img { height: 100%; }
  }

  /* Gradient overlay */
  .shop-fs-gradient {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(0deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.4) 35%, transparent 60%),
      linear-gradient(90deg, rgba(0,0,0,0.35) 0%, transparent 40%);
    pointer-events: none;
    z-index: 1;
  }

  /* Content overlay */
  .shop-fs-content {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    z-index: 2;
    padding: 24px 20px 50px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
  }
  @media (min-width: 768px) {
    .shop-fs-content { padding: 32px 40px 50px; }
  }
  @media (min-width: 1024px) {
    .shop-fs-content { padding: 32px 64px 50px; }
  }
  @media (max-width: 768px) {
    .shop-fs-content {
      padding: 10px 16px 40px;
      gap: 8px;
      flex-direction: column;
      align-items: flex-start;
    }
  }

  .shop-fs-info { max-width: 500px; }
  .shop-fs-colorway {
    font-family: 'inconsolata' !important;
    text-transform: uppercase;
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,0.5) !important;
    margin-bottom: 6px;
  }
  @media (max-width: 768px) {
    .shop-fs-colorway { font-size: 0.55rem; margin-bottom: 3px; }
  }
  .shop-fs-name {
    font-size: 2rem;
    line-height: 1.05;
    margin-bottom: 6px;
  }
  @media (min-width: 768px) { .shop-fs-name { font-size: 2.5rem; } }
  @media (min-width: 1024px) { .shop-fs-name { font-size: 3rem; } }
  @media (max-width: 768px) { .shop-fs-name { font-size: 1.4rem; margin-bottom: 3px; } }

  .shop-fs-meta {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.45) !important;
    margin-bottom: 8px;
  }
  @media (max-width: 768px) {
    .shop-fs-meta { font-size: 0.65rem; margin-bottom: 4px; }
  }

  .shop-fs-swatches {
    display: flex;
    gap: 6px;
    margin-top: 10px;
  }
  @media (max-width: 768px) {
    .shop-fs-swatches { margin-top: 6px; gap: 5px; }
  }
  .shop-fs-swatch {
    width: 14px; height: 14px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.4);
    box-shadow: 0 2px 6px rgba(0,0,0,0.3);
  }
  @media (max-width: 768px) {
    .shop-fs-swatch { width: 11px; height: 11px; }
  }

  .shop-fs-cta {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
  }
  @media (max-width: 768px) {
    .shop-fs-cta { flex-direction: row; align-items: center; gap: 8px; align-self: stretch; }
  }
  .shop-fs-btn {
    display: inline-block;
    padding: 10px 28px;
    border-radius: 8px;
    font-family: 'inconsolata' !important;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.75rem;
    background: linear-gradient(135deg, #6B00CC, #FF6611);
    color: #fff !important;
    transition: opacity 0.2s, transform 0.2s;
    white-space: nowrap;
  }
  @media (max-width: 768px) {
    .shop-fs-btn { padding: 8px 18px; font-size: 0.65rem; }
  }
  .shop-fs-btn:hover { opacity: 0.9; transform: translateY(-2px); }
  .shop-fs-btn-next {
    background: rgba(107,0,204,0.2) !important;
    border: 1px solid rgba(107,0,204,0.4);
  }
  .shop-fs-btn-next:hover { opacity: 1; transform: none; }

  .shop-fs-btn-outline {
    display: inline-block;
    padding: 8px 24px;
    border-radius: 8px;
    font-family: 'inconsolata' !important;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.7rem;
    border: 1px solid rgba(255,255,255,0.25);
    color: rgba(255,255,255,0.7) !important;
    transition: all 0.2s;
    white-space: nowrap;
  }
  @media (max-width: 768px) {
    .shop-fs-btn-outline { display: none; }
  }
  .shop-fs-btn-outline:hover {
    border-color: rgba(255,255,255,0.6);
    color: #fff !important;
  }

  .shop-fs-carousel .flickity-page-dots {
    bottom: 14px !important;
    padding-bottom: 0 !important;
    z-index: 3;
  }
</style>

<section id="shop-preview" style="background: #000;">
  <div class="shop-fs-carousel">
    {slides.map((slide) => (
      <div class="shop-fs-cell">
        <div class="shop-fs-images">
          <div class="shop-fs-img">
            <img src={slide.img1} alt={`${slide.name} — front`} loading="lazy" />
          </div>
          <div class="shop-fs-img">
            <img src={slide.img2} alt={`${slide.name} — detail`} loading="lazy" />
          </div>
        </div>
        <div class="shop-fs-gradient"></div>
        <div class="shop-fs-content">
          <div class="shop-fs-info">
            <p class="shop-fs-colorway">{slide.colorway}</p>
            <h2 class="shop-fs-name">{slide.name}</h2>
            <p class="shop-fs-meta">{slide.fit} · {slide.code}</p>
            <div class="shop-fs-swatches">
              {slide.swatches.map(s => (
                <span class="shop-fs-swatch" style={`background: ${s}`}></span>
              ))}
            </div>
          </div>
          <div class="shop-fs-cta">
            {slide.nextDrop ? (
              <a href={`/shop/${slide.slug}`} class="shop-fs-btn shop-fs-btn-next">Next Drop</a>
            ) : (
              <a href={`/shop/${slide.slug}`} class="shop-fs-btn">Pre-Order Now</a>
            )}
            <a href="/shop" class="shop-fs-btn-outline">View All</a>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  var shopFsFlkty = new Flickity('.shop-fs-carousel', {
    cellAlign: 'left',
    contain: true,
    prevNextButtons: false,
    pageDots: true,
    wrapAround: true,
    autoPlay: 4500,
    pauseAutoPlayOnHover: true,
    imagesLoaded: true,
    draggable: true,
  });
</script>
