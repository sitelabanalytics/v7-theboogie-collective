---
import { allProducts } from "../data/products.js";

// Pick featured products for homepage slider
const featured = allProducts.filter(p =>
  ["classic-oversized-tee-purple-black", "classic-oversized-tee-orange-black", "box-hood-purple-black", "womens-crop-tee-purple-black", "box-hood-white-stitch", "classic-oversized-tee-white-stitch"].includes(p.slug)
);
---

<!-- CSS -->
<link rel="stylesheet" href="https://unpkg.com/flickity@2/dist/flickity.min.css">
<!-- JavaScript -->
<script is:inline src="https://unpkg.com/flickity@2/dist/flickity.pkgd.min.js"></script>

<style is:global>
  .shop-slider-cell {
    margin-right: 12px;
    width: 280px;
    border-radius: 12px;
    overflow: hidden;
    background: linear-gradient(165deg, rgba(2, 0, 36, 0.5) 0%, rgba(9, 9, 121, 0.15) 65%, rgba(0, 213, 255, 0.08) 100%);
    border: 0.5px solid rgba(255, 255, 255, 0.08);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.3s;
  }
  .shop-slider-cell:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 255, 255, 0.15);
  }
  @media (min-width: 768px) {
    .shop-slider-cell { width: 300px; }
  }

  .shop-slider-cell-img {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #111;
    position: relative;
  }
  .shop-slider-cell-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .shop-slider-cell:hover .shop-slider-cell-img img {
    transform: scale(1.05);
  }
  .shop-slider-cell-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    font-family: 'inconsolata';
    text-transform: uppercase;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    padding: 3px 8px;
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(12px);
    border: 0.5px solid rgba(255, 255, 255, 0.2);
    border-radius: 4px;
    color: #fff;
  }
  .shop-slider-cell-swatch {
    position: absolute;
    bottom: 10px;
    left: 10px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.4);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  .shop-slider-cell-body {
    padding: 16px;
  }
  .shop-slider-cell-colorway {
    font-family: 'inconsolata' !important;
    text-transform: uppercase;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.45) !important;
    margin-bottom: 2px;
  }
  .shop-slider-cell-name {
    font-size: 1.1rem;
    margin-bottom: 4px;
  }
  .shop-slider-cell-meta {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.35) !important;
    margin-bottom: 12px;
  }
  .shop-slider-cell-btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 8px 16px;
    border-radius: 6px;
    font-family: 'inconsolata' !important;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.7rem;
    background: linear-gradient(135deg, #6B00CC, #FF6611);
    color: #fff !important;
    transition: opacity 0.2s;
  }
  .shop-slider-cell-btn:hover { opacity: 0.9; }

  /* Flickity overrides for shop slider */
  .shop-carousel { max-width: 100vw !important; }
  .shop-carousel .flickity-viewport {
    min-height: 1px;
    overflow: visible;
  }
</style>

<section id="shop-preview" class="py-12" style="background: #000;">
  <div class="px-5 md:px-10 lg:px-16 mb-8 flex flex-row items-end justify-between">
    <div>
      <h5 class="text-xs md:text-sm">Shop</h5>
      <h4 class="text-2xl md:text-3xl lg:text-4xl my-2 font-bold lg:tracking-tight">
        The Collection.
      </h4>
    </div>
    <a href="/shop" class="rounded text-center transition px-5 py-2 text-sm border border-white/20 hover:border-white/50 text-white mb-2">
      View All
    </a>
  </div>

  <div class="shop-carousel">
    {featured.map((product) => (
      <a href={`/shop/${product.slug}`} class="shop-slider-cell">
        <div class="shop-slider-cell-img">
          <img src={product.image} alt={`${product.name} — ${product.colorway}`} loading="lazy" />
          {product.badge && <span class="shop-slider-cell-badge">{product.badge}</span>}
          <span class="shop-slider-cell-swatch" style={`background: ${product.swatch}`}></span>
        </div>
        <div class="shop-slider-cell-body">
          <p class="shop-slider-cell-colorway">{product.colorway}</p>
          <h4 class="shop-slider-cell-name">{product.name}</h4>
          <p class="shop-slider-cell-meta">{product.fit} · {product.code}</p>
          <span class="shop-slider-cell-btn">View Product</span>
        </div>
      </a>
    ))}
  </div>
</section>

<script is:inline>
  var shopFlkty = new Flickity('.shop-carousel', {
    cellAlign: 'left',
    contain: true,
    prevNextButtons: false,
    pageDots: true,
    freeScroll: true,
    imagesLoaded: true
  });
</script>
