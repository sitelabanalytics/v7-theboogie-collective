---
// @ts-ignore
import { Icon } from "astro-icon";
import Link from "@components/ui/link.astro";
import { Picture } from "@astrojs/image/components";
import Slider from '../assets/tbc/gal-boho-1.jpg';
import SliderLrg from '../assets/tbc/gal-boho-2.webp';
import Hero from '../assets/tbc/gal-boho-3.webp';


const services = [
  {
    imgsrc: Hero,
    imgalt: "Advertising with Google for free through organic SEO improvements.",
  },
  {
    imgsrc: Slider,
    imgalt: "Advertising with Google for free through organic SEO improvements.",
  },
  {
    imgsrc: SliderLrg,
    imgalt: "Advertising with Google for free through organic SEO improvements.",
  },
  
];
---


<!-- CSS -->
<link rel="stylesheet" href="https://unpkg.com/flickity@2/dist/flickity.min.css">
<!-- JavaScript -->
<script is:inline src="https://unpkg.com/flickity@2/dist/flickity.pkgd.min.js"></script>


<!-- Flickity Custom Styles -->
<style>
.carousel-cell {
    margin-right: 3px;
    margin-bottom: 20px;
    border-radius: 0;
    aspect-ratio: 5 / 3;
    max-height: 240px;
    max-width: 480px;
    overflow: hidden;
  }
  .carousel-cell img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Start Flickity viewport safeguards V5 — explicit dimensions before JS init */
  main { max-width: 100%; }
  .boho-carousel { max-width: 100vw !important; height: auto; }
  .boho-carousel .flickity-viewport {
    margin: 0 auto;
    max-width: 100vw !important;
    max-height: 240px;
    transition: height 0.3s ease;
  }
  /* End Flickity viewport safeguards V5 */


  #works-row { border: black; border-top: ridge; }
  </style>

<main id="works-row" class="mx-auto mt-12 md:mt-8 pb-4">
<div class="pt-8 px-5 md:px-10 lg:px-16 flex flex-row items-start sm:items-center justify-between">
  <div>
    <h5 class="text-xs md:text-sm lg:text-md">
      Stage Build
    </h5>
    <h4 class="text-2xl md:text-3xl lg:text-5xl my-2 font-bold lg:tracking-tight">
      Bohemian Beatfreaks 2018.
    </h4>
  </div>
  <div class="my-6">
    <Link 
        class="text-xs md:text-sm"
        href="/contact"
        style="outline">
        Contact
      </Link>
  </div>
</div>

<div id="sliderContainer" class="boho-carousel">
  {
    services.map((item) => (
      <div class="carousel-cell flex flex-row justify-start items-center w-full sm:w-4/5 lg:w-3/4">
        <Picture
              src={item.imgsrc}
              sizes="(max-width: 1680px) 1680px, 1260px, 840px"
              widths={[840, 1260, 1680]}
              aspectRatio="5:3"
              loading="eager"
              background="#f2f2f200"
              fit="cover"
              position="center"
              class="w-full h-full"
            />
      </div>
    ))
  }
</div>
</main>

<script is:inline>
  var flkty = new Flickity( '.boho-carousel', {
  cellAlign: 'left',
  contain: true,
  prevNextButtons: false,
  pageDots: true,
  imagesLoaded: true
  });
</script>

