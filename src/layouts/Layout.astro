---
import { SEO } from "astro-seo";
import Footer from "@components/footer.astro";
import Detailedfooter from "@components/detailed-footer.astro";
import Navbar from "@components/navbar/navbar.astro";
import "@fontsource/inter/variable.css";
import '../styles/main.css';

export interface Props {
  title: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site
).toString();

const { title } = Astro.props;

const makeTitle = title
  ? title + " | " + "The Boogie Collective"
  : "Outdoor events and artists across the Eastern Australian Coast. Event installations, lighting and stage design as Immersive Structures. Helping you stop dancing inside since 2016.";
---


<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link id="favicon" rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      (function() {
        var favicons = ['/favicon.svg', '/favicon-orange.svg', '/favicon-purple.svg', '/favicon-purple2.svg'];
        var link = document.getElementById('favicon');
        if (link) link.href = favicons[Math.floor(Math.random() * favicons.length)];
      })();
    </script>
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap.xml">
    

    <!-- <link rel="preload" as="image" href={src} alt="Hero" /> -->
    <SEO
      title={makeTitle}
      description="Australian outdoor electronic music label and events. Home of Happiness Hill festival. Limited release merch, artist bookings, and immersive stage installations."
      canonical={canonicalURL}
      twitter={{
        creator: "@theboogiecollective",
        site: "@theboogiecollective",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: `The Boogie Collective | Outdoor Electronic Music Label`,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "The Boogie Collective - Australian outdoor electronic music label and events.",
        },
      }}
    />


  <style>
    html { max-width: 100vw; overflow-x: hidden; }
  </style>
  
  <body style="background: var(--bg); transition: background 0.3s;">
    <Navbar />
    <slot />
    <Detailedfooter />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>


