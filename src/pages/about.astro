---
import Layout from "@layouts/Layout.astro";
import ContainerFW from "@components/container-fullwidth.astro";
import Container from "@components/container.astro";
import { Picture } from "@astrojs/image/components";
import { Icon } from "astro-icon";

import HeroImg from '../assets/tbc/hh2-stage-lrg.jpg';
import EventsImg from '../assets/tbc/gal-hh2-1.jpg';
import ImmersiveImg from '../assets/tbc/immersive-2.jpg';
import LabelImg from '../assets/tbc/gal-boho-1.jpg';
import MerchImg from '../assets/tbc/DSC01565.jpg';
import PhilosophyImg from '../assets/tbc/gal-hh1-2.jpg';
---

<Layout title="About">

  <!-- Hero Section -->
  <ContainerFW>
    <style>
      #aboutHero {
        background-image: url('../assets/tbc/hh2-stage-lrg.jpg');
        background-repeat: no-repeat;
        background-size: cover;
        background-position: center;
        min-height: 55vh;
      }
      @media only screen and (max-width: 1199px) {
        #aboutHero {
          min-height: 65vh;
        }
      }
      @media only screen and (max-width: 768px) {
        #aboutHero {
          min-height: 80vh;
        }
      }
    </style>

    <main class="my-8 md:my-16">
      <div id="aboutHero" class="mx-auto flex flex-row items-end rounded-3xl">
        <div>
          <div id="glass-card" class="max-w-4xl mx-4 my-8">
            <h5 class="text-xs md:text-sm lg:text-md mb-2">Est. 2016</h5>
            <h1 class="text-4xl sm:text-5xl md:text-4xl lg:text-6xl xl:text-7xl w-full max-w-6xl font-bold tracking-tight">
              About The Boogie Collective.
            </h1>
            <p class="text-md lg:text-lg mt-4 max-w-2xl">
              Australian music label and events company built around outdoor electronic music, immersive stage design, and a community that keeps coming back to the dust.
            </p>
          </div>
        </div>
      </div>
    </main>
  </ContainerFW>


  <!-- About / Origin Section -->
  <Container>
    <div class="my-8 md:my-16 grid md:grid-cols-2 gap-8 md:gap-16 items-center">
      <div>
        <h5 class="text-xs md:text-sm lg:text-md mb-2">Our Story</h5>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold lg:tracking-tight mb-6">
          Born from the dancefloor.
        </h2>
        <p class="text-md lg:text-lg mb-4">
          The Boogie Collective started in 2016 as a platform to promote and book outdoor electronic DJs and producers across Australia. Back then, the outdoor events scene was less organised and harder to navigate for both artists and punters. We saw a gap and filled it with lineups that made sense, stages that felt right, and events that people actually wanted to come back to.
        </p>
        <p class="text-md lg:text-lg mb-4">
          Over the years, TBC evolved from a booking platform into a full music label and promotion team. We now release music, curate multi-day festivals, design and build immersive stage installations, and run a merch line -- all while staying rooted in the same community and sound that started it all.
        </p>
        <p class="text-md lg:text-lg">
          Based in South East Queensland, everything we do is built around outdoor electronic music and the people who live for it.
        </p>
      </div>
      <div>
        <Picture
          id="glass-card-dark"
          src={EventsImg}
          sizes="(max-width: 800px) 100vw, 600px"
          widths={[400, 600]}
          aspectRatio="4:5"
          background="#f2f2f2"
          fit="cover"
          position="center"
          class="w-full rounded duration-200 hover:shadow-sm"
        />
      </div>
    </div>
  </Container>


  <!-- What We Do Section -->
  <Container>
    <div class="my-8 md:my-16">
      <h5 class="text-xs md:text-sm lg:text-md mb-2">What We Do</h5>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold lg:tracking-tight mb-10">
        Four sides of the same coin.
      </h2>

      <div class="grid md:grid-cols-2 gap-4">

        <!-- Music Label -->
        <div id="glass-card" class="flex flex-col">
          <div class="mb-4">
            <svg viewBox="0 0 24 24" class="w-8 h-8">
              <Icon class="text-white" name="ph:planet-light" />
            </svg>
          </div>
          <h3 class="text-2xl md:text-3xl font-bold lg:tracking-tight mb-3">
            Music Label.
          </h3>
          <p class="text-md lg:text-lg">
            We release music from artists who understand the outdoor sound. Deep, driving, and built for open air. Our catalogue spans house, techno, minimal, and everything that sits between genres when the sun goes down. Available on all major streaming platforms.
          </p>
        </div>

        <!-- Event Curation -->
        <div id="glass-card" class="flex flex-col">
          <div class="mb-4">
            <svg viewBox="0 0 24 24" class="w-8 h-8">
              <Icon class="text-white" name="ph:film-slate-light" />
            </svg>
          </div>
          <h3 class="text-2xl md:text-3xl font-bold lg:tracking-tight mb-3">
            Event Curation.
          </h3>
          <p class="text-md lg:text-lg">
            Happiness Hill is our flagship three-day festival held deep in the Queensland hinterland. Happiness Valley is its sister format -- intimate single-night outdoor sessions across South East QLD. We only run events when they can be fully realised. No half measures.
          </p>
        </div>

        <!-- Immersive Structures -->
        <div id="glass-card" class="flex flex-col">
          <div class="mb-4">
            <svg viewBox="0 0 24 24" class="w-8 h-8">
              <Icon class="text-white" name="ph:codepen-logo-light" />
            </svg>
          </div>
          <h3 class="text-2xl md:text-3xl font-bold lg:tracking-tight mb-3">
            Immersive Structures.
          </h3>
          <p class="text-md lg:text-lg">
            3D stage design, lighting installations, and bamboo construction for over 50 events across the Eastern Coast of Australia. We design and build the environments that make outdoor events feel like somewhere else entirely. Every structure is purpose-built for the site and the sound.
          </p>
        </div>

        <!-- Merch -->
        <div id="glass-card" class="flex flex-col">
          <div class="mb-4">
            <svg viewBox="0 0 24 24" class="w-8 h-8">
              <Icon class="text-white" name="ph:shopping-cart-light" />
            </svg>
          </div>
          <h3 class="text-2xl md:text-3xl font-bold lg:tracking-tight mb-3">
            Merch.
          </h3>
          <p class="text-md lg:text-lg">
            Limited release prints, apparel, and event-exclusive drops. Our merch is designed in-house and produced in small runs. When it sells out, it stays sold out. Each release ties back to a specific event or moment in the collective's history.
          </p>
        </div>

      </div>
    </div>
  </Container>


  <!-- Philosophy Section -->
  <ContainerFW>
    <style>
      #philosophySection {
        background-image: url('../assets/tbc/gal-hh1-2.jpg');
        background-repeat: no-repeat;
        background-size: cover;
        background-position: center;
        min-height: 40vh;
      }
      @media only screen and (max-width: 768px) {
        #philosophySection {
          min-height: 60vh;
        }
      }
    </style>

    <main class="my-8 md:my-16">
      <div id="philosophySection" class="mx-auto flex flex-col items-start justify-end rounded-3xl">
        <div id="glass-card" class="max-w-3xl mx-4 my-8">
          <h5 class="text-xs md:text-sm lg:text-md mb-2">Philosophy</h5>
          <h3 class="text-3xl md:text-4xl lg:text-5xl font-bold lg:tracking-tight mb-4">
            Outdoor music is the point.
          </h3>
          <p class="text-md lg:text-lg mb-4">
            Queensland has some of the best conditions on Earth for outdoor electronic music. Warm nights, open land, and communities scattered across the hinterland who understand what it means to gather under the stars with good sound. TBC exists to protect and grow that culture.
          </p>
          <p class="text-md lg:text-lg">
            We believe events should be intentional, not frequent. That lineups should be curated, not crowded. That the space between stages matters as much as the sound on them. Every decision we make comes back to one question: does this make the dancefloor better?
          </p>
        </div>
      </div>
    </main>
  </ContainerFW>


  <!-- CTA Section -->
  <Container>
    <div class="my-8 md:my-16 text-center max-w-3xl mx-auto">
      <h5 class="text-xs md:text-sm lg:text-md mb-2">Get Involved</h5>
      <h3 class="text-3xl md:text-4xl lg:text-5xl font-bold lg:tracking-tight mb-4">
        Join the Collective.
      </h3>
      <p class="text-md lg:text-lg mb-8">
        Whether you want to book us for an event, submit a demo to the label, or grab some merch before it disappears -- we would love to hear from you.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-3">
        <a href="/contact" class="rounded text-center transition focus-visible:ring-2 ring-offset-2 ring-gray-200 px-5 py-2.5 bg-white text-black hover:bg-gray-200 border-2 border-transparent flex gap-1 items-center justify-center">
          <svg viewBox="0 0 24 24" class="w-4 h-4">
            <Icon class="text-black" name="ph:chat-teardrop-dots-light" />
          </svg>
          Contact for Bookings
        </a>
        <a href="/shop" class="rounded text-center transition focus-visible:ring-2 ring-offset-2 ring-gray-200 px-5 py-2.5 bg-transparent text-white hover:bg-white/10 border-2 border-white/30 flex gap-1 items-center justify-center">
          <svg viewBox="0 0 24 24" class="w-4 h-4">
            <Icon class="text-white" name="ph:shopping-cart-light" />
          </svg>
          Browse Merch
        </a>
      </div>
    </div>
  </Container>

</Layout>
