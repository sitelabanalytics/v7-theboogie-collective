---
import Layout from "@layouts/Layout.astro";
import ContainerFW from "@components/container-fullwidth.astro";
import ContainerXL from "@components/container-xl.astro";
import Container from "@components/container.astro";
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon";

const artists = [
  {
    name: "Boog",
    genre: "Bush Techno / Progressive",
    location: "QLD, AU",
    description:
      "Founder of The Boogie Collective. Bush techno and progressive sets since 2016.",
    soundcloud: "https://soundcloud.com/theboogiecollective",
  },
  {
    name: "Simrana",
    genre: "Progressive Electronic",
    location: "Eastern Coast, AU",
    description:
      "Progressive electronic producer. Releases on Weaver Agency and Techgnosis Records.",
    soundcloud: "https://soundcloud.com/simranasounds",
  },
  {
    name: "Scrub Rat",
    genre: "Breaks / Dub",
    location: "Tasmania",
    description:
      "Tasmania based breaks and dub artist with some of the best mixing you'll find on the Australian outdoor circuit.",
    soundcloud: "https://soundcloud.com/scrubrataus",
  },
  {
    name: "Lucid Gecko",
    genre: "Psytrance / Breaks / DnB",
    location: "Sunshine Coast, QLD",
    description:
      "Sunshine Coast hinterland inspired morning psytrance, breaks and DnB sounds. A versatile selector for any stage.",
    soundcloud: "https://soundcloud.com/lucid-gecko",
  },
  {
    name: "Akudama",
    genre: "Progressive Full-On",
    location: "Mid Coast, AU",
    description:
      "Warehouse inspired progressive full-on out of the Mid Australian Coast. Releases on Padang Records.",
    soundcloud: "https://soundcloud.com/akudamaa",
  },
  {
    name: "Jiver",
    genre: "Warehouse Techno / Tech",
    location: "Brisbane, QLD",
    description:
      "Brisbane based warehouse techno and tech. One of Brisbane's most exciting upcoming artists.",
    soundcloud: "https://soundcloud.com/jiver-2",
  },
  {
    name: "Nemophilist",
    genre: "Deep Psytrance",
    location: "Central Coast, NSW",
    description:
      "One of the best upcoming deep psytrance artists out of the central coast. Forest-floor frequencies.",
    soundcloud: "https://soundcloud.com/joshua-hyde",
  },
  {
    name: "D-Lysergic",
    genre: "Psytrance",
    location: "Central Coast, NSW",
    description:
      "Central coast psytrance artist creating great events and sets for over 15 years. A true veteran of the scene.",
    soundcloud: "https://soundcloud.com/d-lysergic",
  },
  {
    name: "Sassafras",
    genre: "Dark Techno / Deep Progressive",
    location: "Brisbane, QLD",
    description:
      "Brisbane dark techno and deep progressive tech. Always spinning ruckus, always raising dust.",
    soundcloud: "https://soundcloud.com/sassafrasaus",
  },
  {
    name: "Mood:Blend",
    genre: "Bush Techno / Progressive",
    location: "Cairns, QLD",
    description:
      "Cairns born, disco and soul inspired bush techno and progressive tech. A signature sound shaped by the far north tropics.",
    soundcloud: "https://soundcloud.com/moodblend",
  },
];
---

<Layout title="Artists">

  <!-- Hero Section -->
  <ContainerFW>
    <main class="my-8 md:my-16">
      <div id="artistsHero" class="mx-auto flex flex-row items-end rounded-3xl">
        <div>
          <div id="glass-card" class="max-w-3xl mx-4 my-8">
            <h5 class="text-sm lg:text-md mb-2">
              The Roster
            </h5>
            <h1 class="text-4xl sm:text-5xl md:text-4xl lg:text-6xl xl:text-7xl w-full max-w-6xl font-bold tracking-tight">
              Our Artists.
            </h1>
            <p class="text-md lg:text-lg mt-4">
              The Boogie Collective represents a curated roster of outdoor electronic artists from across
              the Eastern Australian coast. From bush techno to deep psytrance, our artists bring
              authentic sounds shaped by the Australian landscape.
            </p>
            <div class="mt-6 flex flex-col sm:flex-row justify-start gap-3">
              <Link href="/contact" style="primary">
                Booking Enquiries
              </Link>
              <Link href="/#artists" style="outline">
                Back to Home
              </Link>
            </div>
          </div>
        </div>
      </div>
    </main>
  </ContainerFW>

  <!-- Intro Section -->
  <Container>
    <div class="text-center max-w-3xl mx-auto py-8 md:py-16">
      <h5 class="text-sm lg:text-md mb-4">
        Eastern Australian Coast
      </h5>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight mb-6">
        Helping you stop dancing inside.
      </h2>
      <p class="text-md lg:text-lg">
        What started as a platform to connect underground DJs with the right stages has grown into
        a music label and promotion team. We work with artists who understand that the best sets
        happen under open sky, surrounded by nature and community.
      </p>
    </div>
  </Container>

  <!-- Artist Grid -->
  <ContainerXL>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-8 mb-8 md:mb-16">
      {
        artists.map((artist) => (
          <div class="flex items-start">
            <div id="glass-card" class="w-full flex flex-col items-start justify-center">
              <div class="w-full">
                <h5 class="text-xs mb-2">{artist.location}</h5>
                <h2 class="font-semibold text-xl md:text-2xl lg:text-3xl">{artist.name}</h2>
                <p class="text-xs md:text-sm mt-1 opacity-60">{artist.genre}</p>
                <p class="text-xs md:text-md mt-4 leading-relaxed">{artist.description}</p>
              </div>
              <div class="pt-6 flex gap-2">
                <Link
                  href={artist.soundcloud}
                  style="primary"
                  size="md"
                  target="_blank"
                  rel="noopener">
                  Music
                </Link>
                <Link
                  href="/contact"
                  style="outline"
                  size="md">
                  Book
                </Link>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </ContainerXL>

  <!-- Booking CTA -->
  <ContainerFW>
    <div class="px-4 md:px-16 lg:px-32 my-16 md:my-32 py-16 md:py-32 mx-4 md:mx-16 rounded-lg flex flex-col items-center text-center" style="background-color: #26003a;">
      <h4 class="text-white font-bold text-3xl md:text-6xl lg:text-7xl xl:text-8xl tracking-tight">
        Book our artists.
      </h4>
      <p class="text-slate-300 px-4 lg:px-16 my-8 text-md md:text-lg">
        Looking to book an artist for your next outdoor event? We handle bookings for our full roster
        and can help you find the right sound for any stage, any time slot, any vibe.
      </p>
      <div class="flex gap-3">
        <Link href="/contact" style="inverted">Get in Touch</Link>
      </div>
    </div>
  </ContainerFW>

</Layout>

<style>
  #artistsHero {
    background-image: url('../assets/tbc/uv-banners.jpg');
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center;
    min-height: 45vh;
  }
  @media only screen and (max-width: 1199px) {
    #artistsHero {
      min-height: 55vh;
    }
  }
  @media only screen and (max-width: 768px) {
    #artistsHero {
      min-height: 70vh;
    }
  }
</style>
