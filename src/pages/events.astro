---
import Layout from "@layouts/Layout.astro";
import ContainerFW from "@components/container-fullwidth.astro";
import ContainerXL from "@components/container-xl.astro";
import Container from "@components/container.astro";
import SectionHeadImg from "@components/sectionhead-img.astro";
import { Picture } from "@astrojs/image/components";
import { Icon } from "astro-icon";

import HeroImg from '../assets/tbc/hh2-stage-lrg.jpg';
import HH1Cover from '../assets/tbc/gal-hh1-1.webp';
import HH2Cover from '../assets/tbc/hh2-hero.webp';

import GalHH1_1 from '../assets/tbc/gal-hh1-1.webp';
import GalHH1_2 from '../assets/tbc/gal-hh1-2.jpg';
import GalHH1_3 from '../assets/tbc/gal-hh1-3.webp';
import GalHH2_1 from '../assets/tbc/gal-hh2-1.jpg';
import GalHH2_2 from '../assets/tbc/gal-hh2-2.webp';
import GalHH2_3 from '../assets/tbc/gal-hh2-3.jpg';
import GalHH2_4 from '../assets/tbc/gal-hh2-4.jpg';
import GalBoho1 from '../assets/tbc/gal-boho-1.jpg';
import GalBoho2 from '../assets/tbc/gal-boho-2.webp';
import GalBoho3 from '../assets/tbc/gal-boho-3.webp';
import GalDD1 from '../assets/tbc/gal-dd-1.webp';
import GalDD2 from '../assets/tbc/gal-dd-2.webp';
import GalRabbits1 from '../assets/tbc/gal-rabbits-1.jpg';
import GalRabbits2 from '../assets/tbc/gal-rabbits-2.webp';
import GalRabbits3 from '../assets/tbc/gal-rabbits-3.webp';

const galleryImages = [
  { src: GalHH2_1, alt: "Happiness Hill 2 crowd under the lights" },
  { src: GalBoho1, alt: "Boho event dancefloor" },
  { src: GalHH1_2, alt: "Happiness Hill 1 sunset session" },
  { src: GalDD1, alt: "Dawn to Dusk event" },
  { src: GalRabbits1, alt: "Down the Rabbit Hole event" },
  { src: GalHH2_3, alt: "Happiness Hill 2 stage at night" },
  { src: GalBoho2, alt: "Boho event crowd" },
  { src: GalRabbits2, alt: "Down the Rabbit Hole dancefloor" },
  { src: GalDD2, alt: "Dawn to Dusk festival goers" },
  { src: GalHH1_3, alt: "Happiness Hill 1 immersive lighting" },
  { src: GalBoho3, alt: "Boho outdoor stage" },
  { src: GalHH2_4, alt: "Happiness Hill 2 late night set" },
];
---

<Layout title="Events">

  <!-- Hero Section -->
  <ContainerFW>
    <style>
      #eventsHero {
        background-image: url('../assets/tbc/hero-hh2-stage-night-med.jpg');
        background-repeat: no-repeat;
        background-size: cover;
        background-position: center;
        min-height: 55vh;
      }
      @media only screen and (max-width: 1199px) {
        #eventsHero {
          min-height: 65vh;
        }
      }
      @media only screen and (max-width: 768px) {
        #eventsHero {
          min-height: 80vh;
        }
      }
    </style>

    <main class="my-8 md:my-16">
      <div id="eventsHero" class="mx-auto flex flex-row items-end rounded-3xl">
        <div>
          <div id="glass-card" class="max-w-4xl mx-4 my-8">
            <h5 class="text-xs md:text-sm lg:text-md mb-2">The Boogie Collective</h5>
            <h1 class="text-4xl sm:text-5xl md:text-4xl lg:text-6xl xl:text-7xl w-full max-w-6xl font-bold tracking-tight">
              Our Events.
            </h1>
            <p class="text-md lg:text-lg mt-4 max-w-2xl">
              From three-day festivals deep in the Queensland hinterland to single-night sessions
              under the stars. We only run events when they can be fully realised.
            </p>
            <div class="mt-6 flex flex-col sm:flex-row justify-start gap-3">
              <a href="#happiness-hill" class="rounded text-center transition focus-visible:ring-2 ring-offset-2 ring-gray-200 px-5 py-2.5 bg-white text-black hover:bg-gray-200 border-2 border-transparent flex gap-1 items-center justify-center">
                <svg viewBox="0 0 24 24" class="w-4 h-4">
                  <Icon class="text-black" name="ph:mountains-light" />
                </svg>
                Happiness Hill
              </a>
              <a href="#happiness-valley" class="rounded text-center transition focus-visible:ring-2 ring-offset-2 ring-gray-200 px-5 py-2.5 bg-transparent text-white hover:bg-white/10 border-2 border-white/30 flex gap-1 items-center justify-center">
                <svg viewBox="0 0 24 24" class="w-4 h-4">
                  <Icon class="text-white" name="ph:music-notes-light" />
                </svg>
                Happiness Valley
              </a>
            </div>
          </div>
        </div>
      </div>
    </main>
  </ContainerFW>


  <!-- Happiness Hill Section -->
  <Container>
    <div id="happiness-hill" class="scroll-mt-24">
      <SectionHeadImg>
        <Fragment slot="smltitle">
          Flagship Festival
        </Fragment>
        <Fragment slot="title">
          Happiness Hill.
        </Fragment>
        <Fragment slot="desc">
          Our full-feature three-day outdoor electronic music festival, held in the forests surrounding
          Jimna, QLD. Happiness Hill brings together hand-picked local and interstate artists across
          multiple stages, immersive art installations, and a community that has been building since 2016.
          Set among the trees with no phone signal and no distractions, just three days of music, dust,
          and good people. Every edition is different. Every edition is intentional.
        </Fragment>
        <Fragment slot="cover">
          <Picture id="glass-card-dark"
                    src={HH2Cover}
                    sizes="(max-width: 2000px) 2000px, 1000px"
                    widths={[1000, 1500, 2000]}
                    aspectRatio="1:1"
                    background="#f2f2f2"
                    fit="cover"
                    position="center"
                    class="w-full rounded duration-200 hover:shadow-sm"
                  />
        </Fragment>
      </SectionHeadImg>
    </div>
  </Container>

  <!-- Happiness Hill Gallery Slider -->
  <ContainerFW>
    <link rel="stylesheet" href="https://unpkg.com/flickity@2/dist/flickity.min.css">
    <script is:inline src="https://unpkg.com/flickity@2/dist/flickity.pkgd.min.js"></script>

    <style>
      .hh-carousel-cell {
        margin-right: 3px;
        margin-bottom: 20px;
        border-radius: 0;
        aspect-ratio: 5 / 3;
        min-height: 300px;
        overflow: hidden;
      }
      .hh-carousel-cell img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .hh-carousel { max-width: 100vw !important; height: auto; }
      .hh-carousel .flickity-viewport {
        margin: 0 auto;
        max-width: 100vw !important;
        min-height: 300px;
        transition: height 0.3s ease;
      }
    </style>

    <main class="mx-auto mt-4 md:mt-0 pb-4">
      <div class="pt-4 px-5 md:px-10 lg:px-16 flex flex-row items-start sm:items-center justify-between">
        <div>
          <h5 class="text-xs md:text-sm lg:text-md">
            Past Events
          </h5>
          <h4 class="text-2xl md:text-3xl lg:text-5xl my-2 font-bold lg:tracking-tight">
            Happiness Hill Gallery.
          </h4>
        </div>
      </div>

      <div class="hh-carousel">
        <div class="hh-carousel-cell flex flex-row justify-start items-center w-full sm:w-4/5 lg:w-3/4">
          <Picture src={GalHH2_1} sizes="(max-width: 1680px) 1680px, 1260px, 840px" widths={[840, 1260, 1680]} aspectRatio="5:3" loading="eager" background="#f2f2f200" fit="cover" position="center" class="w-full h-full" />
        </div>
        <div class="hh-carousel-cell flex flex-row justify-start items-center w-full sm:w-4/5 lg:w-3/4">
          <Picture src={GalHH2_2} sizes="(max-width: 1680px) 1680px, 1260px, 840px" widths={[840, 1260, 1680]} aspectRatio="5:3" loading="lazy" background="#f2f2f200" fit="cover" position="center" class="w-full h-full" />
        </div>
        <div class="hh-carousel-cell flex flex-row justify-start items-center w-full sm:w-4/5 lg:w-3/4">
          <Picture src={GalHH1_1} sizes="(max-width: 1680px) 1680px, 1260px, 840px" widths={[840, 1260, 1680]} aspectRatio="5:3" loading="lazy" background="#f2f2f200" fit="cover" position="center" class="w-full h-full" />
        </div>
        <div class="hh-carousel-cell flex flex-row justify-start items-center w-full sm:w-4/5 lg:w-3/4">
          <Picture src={GalHH1_2} sizes="(max-width: 1680px) 1680px, 1260px, 840px" widths={[840, 1260, 1680]} aspectRatio="5:3" loading="lazy" background="#f2f2f200" fit="cover" position="center" class="w-full h-full" />
        </div>
        <div class="hh-carousel-cell flex flex-row justify-start items-center w-full sm:w-4/5 lg:w-3/4">
          <Picture src={GalHH2_3} sizes="(max-width: 1680px) 1680px, 1260px, 840px" widths={[840, 1260, 1680]} aspectRatio="5:3" loading="lazy" background="#f2f2f200" fit="cover" position="center" class="w-full h-full" />
        </div>
        <div class="hh-carousel-cell flex flex-row justify-start items-center w-full sm:w-4/5 lg:w-3/4">
          <Picture src={GalHH2_4} sizes="(max-width: 1680px) 1680px, 1260px, 840px" widths={[840, 1260, 1680]} aspectRatio="5:3" loading="lazy" background="#f2f2f200" fit="cover" position="center" class="w-full h-full" />
        </div>
        <div class="hh-carousel-cell flex flex-row justify-start items-center w-full sm:w-4/5 lg:w-3/4">
          <Picture src={GalHH1_3} sizes="(max-width: 1680px) 1680px, 1260px, 840px" widths={[840, 1260, 1680]} aspectRatio="5:3" loading="lazy" background="#f2f2f200" fit="cover" position="center" class="w-full h-full" />
        </div>
      </div>
    </main>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        if (typeof Flickity !== 'undefined') {
          new Flickity('.hh-carousel', {
            cellAlign: 'left',
            contain: true,
            prevNextButtons: false,
            pageDots: true,
            imagesLoaded: true
          });
        }
      });
    </script>
  </ContainerFW>


  <!-- Happiness Valley Section -->
  <Container>
    <div id="happiness-valley" class="scroll-mt-24">
      <SectionHeadImg>
        <Fragment slot="smltitle">
          Single Night Events
        </Fragment>
        <Fragment slot="title">
          Happiness Valley.
        </Fragment>
        <Fragment slot="desc">
          Our sister format to the festival. Happiness Valley events are single-night outdoor sessions
          held across South East Queensland. Smaller in scale but no less considered. These are intimate
          gatherings built around quality sound, curated lineups, and locations chosen for the way they
          feel after dark. Think hidden clearings, bushland properties, and private land with room to move.
          Valley events are where we test new ideas, give emerging artists a proper stage, and keep the
          community connected between festivals.
        </Fragment>
        <Fragment slot="cover">
          <Picture id="glass-card-dark"
                    src={HH1Cover}
                    sizes="(max-width: 2000px) 2000px, 1000px"
                    widths={[1000, 1500, 2000]}
                    aspectRatio="1:1"
                    background="#f2f2f2"
                    fit="cover"
                    position="center"
                    class="w-full rounded duration-200 hover:shadow-sm"
                  />
        </Fragment>
      </SectionHeadImg>
    </div>
  </Container>

  <!-- Valley / Other Events Gallery Slider -->
  <ContainerFW>
    <style>
      .valley-carousel-cell {
        margin-right: 3px;
        margin-bottom: 20px;
        border-radius: 0;
        aspect-ratio: 5 / 3;
        min-height: 300px;
        overflow: hidden;
      }
      .valley-carousel-cell img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }
      .valley-carousel { max-width: 100vw !important; height: auto; }
      .valley-carousel .flickity-viewport {
        margin: 0 auto;
        max-width: 100vw !important;
        min-height: 300px;
        transition: height 0.3s ease;
      }
    </style>

    <main class="mx-auto mt-4 md:mt-0 pb-4">
      <div class="pt-4 px-5 md:px-10 lg:px-16 flex flex-row items-start sm:items-center justify-between">
        <div>
          <h5 class="text-xs md:text-sm lg:text-md">
            Past Events
          </h5>
          <h4 class="text-2xl md:text-3xl lg:text-5xl my-2 font-bold lg:tracking-tight">
            Valley + One-Night Events.
          </h4>
        </div>
      </div>

      <div class="valley-carousel">
        <div class="valley-carousel-cell flex flex-row justify-start items-center w-full sm:w-4/5 lg:w-3/4">
          <Picture src={GalBoho1} sizes="(max-width: 1680px) 1680px, 1260px, 840px" widths={[840, 1260, 1680]} aspectRatio="5:3" loading="lazy" background="#f2f2f200" fit="cover" position="center" class="w-full h-full" />
        </div>
        <div class="valley-carousel-cell flex flex-row justify-start items-center w-full sm:w-4/5 lg:w-3/4">
          <Picture src={GalBoho2} sizes="(max-width: 1680px) 1680px, 1260px, 840px" widths={[840, 1260, 1680]} aspectRatio="5:3" loading="lazy" background="#f2f2f200" fit="cover" position="center" class="w-full h-full" />
        </div>
        <div class="valley-carousel-cell flex flex-row justify-start items-center w-full sm:w-4/5 lg:w-3/4">
          <Picture src={GalRabbits1} sizes="(max-width: 1680px) 1680px, 1260px, 840px" widths={[840, 1260, 1680]} aspectRatio="5:3" loading="lazy" background="#f2f2f200" fit="cover" position="center" class="w-full h-full" />
        </div>
        <div class="valley-carousel-cell flex flex-row justify-start items-center w-full sm:w-4/5 lg:w-3/4">
          <Picture src={GalDD1} sizes="(max-width: 1680px) 1680px, 1260px, 840px" widths={[840, 1260, 1680]} aspectRatio="5:3" loading="lazy" background="#f2f2f200" fit="cover" position="center" class="w-full h-full" />
        </div>
        <div class="valley-carousel-cell flex flex-row justify-start items-center w-full sm:w-4/5 lg:w-3/4">
          <Picture src={GalRabbits2} sizes="(max-width: 1680px) 1680px, 1260px, 840px" widths={[840, 1260, 1680]} aspectRatio="5:3" loading="lazy" background="#f2f2f200" fit="cover" position="center" class="w-full h-full" />
        </div>
        <div class="valley-carousel-cell flex flex-row justify-start items-center w-full sm:w-4/5 lg:w-3/4">
          <Picture src={GalBoho3} sizes="(max-width: 1680px) 1680px, 1260px, 840px" widths={[840, 1260, 1680]} aspectRatio="5:3" loading="lazy" background="#f2f2f200" fit="cover" position="center" class="w-full h-full" />
        </div>
        <div class="valley-carousel-cell flex flex-row justify-start items-center w-full sm:w-4/5 lg:w-3/4">
          <Picture src={GalRabbits3} sizes="(max-width: 1680px) 1680px, 1260px, 840px" widths={[840, 1260, 1680]} aspectRatio="5:3" loading="lazy" background="#f2f2f200" fit="cover" position="center" class="w-full h-full" />
        </div>
        <div class="valley-carousel-cell flex flex-row justify-start items-center w-full sm:w-4/5 lg:w-3/4">
          <Picture src={GalDD2} sizes="(max-width: 1680px) 1680px, 1260px, 840px" widths={[840, 1260, 1680]} aspectRatio="5:3" loading="lazy" background="#f2f2f200" fit="cover" position="center" class="w-full h-full" />
        </div>
      </div>
    </main>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', function() {
        if (typeof Flickity !== 'undefined') {
          new Flickity('.valley-carousel', {
            cellAlign: 'left',
            contain: true,
            prevNextButtons: false,
            pageDots: true,
            imagesLoaded: true
          });
        }
      });
    </script>
  </ContainerFW>


  <!-- Past Events Grid Gallery -->
  <Container>
    <div class="my-8 md:my-16">
      <h5 class="text-xs md:text-sm lg:text-md mb-2">Gallery</h5>
      <h3 class="max-w-3xl text-2xl md:text-3xl lg:text-5xl font-bold lg:tracking-tight mb-8">
        Moments from the dust.
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-1">
        {galleryImages.map((img) => (
          <div class="aspect-square overflow-hidden">
            <Picture
              src={img.src}
              sizes="(max-width: 800px) 400px, 600px"
              widths={[400, 600]}
              aspectRatio="1:1"
              loading="lazy"
              background="#f2f2f200"
              fit="cover"
              position="center"
              class="w-full h-full object-cover hover:scale-105 duration-500"
            />
          </div>
        ))}
      </div>
    </div>
  </Container>


  <!-- CTA Section -->
  <ContainerFW>
    <style>
      #eventsCta {
        background-image: url('../assets/tbc/hh2-stage-lrg.jpg');
        background-repeat: no-repeat;
        background-size: cover;
        background-position: center;
        min-height: 40vh;
      }
      @media only screen and (max-width: 768px) {
        #eventsCta {
          min-height: 60vh;
        }
      }
    </style>

    <main class="my-8 md:my-16">
      <div id="eventsCta" class="mx-auto flex flex-col items-start justify-end rounded-3xl">
        <div id="glass-card" class="max-w-3xl mx-4 my-8">
          <h5 class="text-xs md:text-sm lg:text-md mb-2">Stay Connected</h5>
          <h3 class="text-3xl md:text-4xl lg:text-5xl font-bold lg:tracking-tight">
            Be the first to know.
          </h3>
          <p class="text-md lg:text-lg mt-4 max-w-xl">
            Our events are invitation-based and sell out through word of mouth.
            Sign up to be notified when we announce our next gathering.
            No spam, just the signal when it matters.
          </p>
          <div class="mt-6 flex flex-col sm:flex-row justify-start gap-3">
            <a href="/contact" class="rounded text-center transition focus-visible:ring-2 ring-offset-2 ring-gray-200 px-5 py-2.5 bg-white text-black hover:bg-gray-200 border-2 border-transparent flex gap-1 items-center justify-center">
              <svg viewBox="0 0 24 24" class="w-4 h-4">
                <Icon class="text-black" name="ph:envelope-simple-light" />
              </svg>
              Sign Up for Notifications
            </a>
          </div>
        </div>
      </div>
    </main>
  </ContainerFW>

</Layout>
