---
import ContainerFW from "@components/container-fullwidth.astro";
import ContainerXL from "@components/container-xl.astro";
import Container from "@components/container.astro";
import { Picture } from "@astrojs/image/components";

import Hero from "@components/hero.astro";
import ShopSlider from "@components/shop-slider.astro";
import ShopVariants from "@components/shop-variants-slider.astro";
import VideoSection from "@components/hero-video-section.astro";

import ContactHero from "@components/hero-end.astro";

import GridSec from "@components/hero-grid-artists-sec.astro";

import ImmersiveSec from "@components/hero-grid-stage-sec.astro";
import StageCover from '../assets/tbc/gal-hh2-2.webp';

import PreviousWorks from "@components/previous-works-slider.astro";
import MixesSlider from "@components/mixes-slider.astro";
import SectionHeadImg from "@components/sectionhead-img.astro";
import ServicesSlider from "@components/services-slider.astro";

import EventsCover from '../assets/tbc/hh2-2-med.jpg';
import EventsCover2 from '../assets/tbc/hh2-3-med.jpg';
import Layout from "@layouts/Layout.astro";





---

<Layout title="Home">
  <ContainerFW class="!pb-0">
    <Hero />
  </ContainerFW>

  <ContainerFW class="!pb-0">
    <VideoSection />
  </ContainerFW>

  <ContainerFW class="!pb-0">
    <ShopSlider />
  </ContainerFW>

  <ContainerFW>
    <ShopVariants />
  </ContainerFW>

  <ContainerFW>
    <ServicesSlider />
  </ContainerFW>

  <Container href="#installations">
    <SectionHeadImg>
      <Fragment slot="smltitle">
        Event Installations
      </Fragment>
      <Fragment slot="title">
        Immersive Structures.
      </Fragment>
      <Fragment slot="desc">
        3D stage design and construction across the Eastern Coast of Australia for over 50 events. Specialist in lighting design and bamboo construction.
      </Fragment>
      <Fragment slot="cover">
        <Picture id="glass-card-dark"
                  src={StageCover}
                  sizes="(max-width: 2000px) 2000px, 1000px"
                  widths={[1000, 1500, 2000]}
                  aspectRatio="1:1"
                  background="#f2f2f2"
                  fit="cover"
                  position="center"
                  class="w-full rounded duration-200 hover:shadow-sm"
                />
      </Fragment>
    </SectionHeadImg>
  </Container>

  <ContainerFW href="#installations">
    <PreviousWorks />
  </ContainerFW>
  
  <Container href="#artists">
    <SectionHeadImg>
      <Fragment slot="smltitle">
        Artists
      </Fragment>
      <Fragment slot="title">
        Outdoor electronic artists.
      </Fragment>
      <Fragment slot="desc">
        The Boogie Collective started as a platform to help promote and book the right artists for the right sets and events in the 
        less organised days of Australian Outdoor Events. Luckily the whole industry has evolved over the years and so have we, turning into 
        a full blown music label and promotion team.
      </Fragment>
      <Fragment slot="cover">
        <Picture  id="glass-card-dark"
                  src={EventsCover2}
                  sizes="(max-width: 2000px) 2000px, 1000px"
                  widths={[1000, 1500, 2000]}
                  aspectRatio="1:1"
                  background="#f2f2f2"
                  fit="cover"
                  position="center"
                  class="w-full rounded duration-200 hover:shadow-sm"
                />
      </Fragment>
    </SectionHeadImg>
  </Container>

  <ContainerXL>
    <GridSec />
  </ContainerXL>

  <ContainerFW>
    <MixesSlider />
  </ContainerFW>

  <Container href="#events">
    <SectionHeadImg>
      <Fragment slot="smltitle">
        Events
      </Fragment>
      <Fragment slot="title">
        Come raise some dust with us.
      </Fragment>
      <Fragment slot="desc">
        We run two formats of events these days. Happiness Hill is our full-feature 3-day event, held in Jimna, QLD. 
        Happiness Valley is our sister single night events. We only run events when they can be fully realised.
      </Fragment>
      <Fragment slot="cover">
        <Picture  id="glass-card-dark"
                  src={EventsCover}
                  sizes="(max-width: 2000px) 2000px, 1000px"
                  widths={[1000, 1500, 2000]}
                  aspectRatio="1:1"
                  background="#f2f2f2"
                  fit="cover"
                  position="center"
                  class="w-full rounded duration-200 hover:shadow-sm"
                />
      </Fragment>
    </SectionHeadImg> 
  </Container>

  <ContainerXL>
    <ImmersiveSec />
  </ContainerXL>

  <ContainerFW>
    <ContactHero />
  </ContainerFW>

  


</Layout>
