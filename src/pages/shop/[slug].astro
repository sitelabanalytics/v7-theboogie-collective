---
import Layout from "@layouts/Layout.astro";
import { products } from "../../data/products.js";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const defaultVariant = product.variants[0];
const fits = [...new Map(product.variants.map(v => [v.fitKey, v.fit])).entries()];
const hasFitSelector = fits.length > 1;
---

<Layout title={product.name}>

  <!-- Variant data -->
  <script id="product-variants" type="application/json" set:html={JSON.stringify(product.variants)}></script>

  <!-- ═══ HERO ═══ -->
  <section class="pdp-hero">
    <!-- Background image -->
    <div class="pdp-hero-img">
      <img id="heroImg" src={defaultVariant.images[0]} alt={defaultVariant.colorway} />
      <div class="pdp-hero-gradient"></div>
    </div>

    <!-- Breadcrumb -->
    <nav class="pdp-breadcrumb pdp-a pdp-a-1">
      <a href="/shop">Shop</a>
      <span>/</span>
      <span>{product.name}</span>
    </nav>

    <!-- Badge -->
    <span class="pdp-hero-badge pdp-a pdp-a-2" id="heroBadge" style={defaultVariant.badge ? '' : 'display:none'}>{defaultVariant.badge || ''}</span>

    <!-- Bottom-left: product info -->
    <div class="pdp-hero-info">
      <p class="pdp-hero-colorway pdp-a pdp-a-2" id="heroColorway">{defaultVariant.colorway}</p>
      <h1 class="pdp-hero-title pdp-a pdp-a-3">{product.name}</h1>
      <div class="pdp-hero-meta pdp-a pdp-a-4">
        <span class="pdp-hero-swatch" id="heroSwatch" style={`background: ${defaultVariant.swatch}`}></span>
        <span id="heroFit">{defaultVariant.fit}</span>
        <span class="pdp-hero-dot">&middot;</span>
        <span id="heroCode">{defaultVariant.code}</span>
      </div>
      <p class="pdp-hero-weight pdp-a pdp-a-5" id="heroWeight">{defaultVariant.weight}</p>
    </div>

    <!-- Bottom-right: selectors + buy -->
    <div class="pdp-hero-action pdp-a pdp-a-5">
      {hasFitSelector && (
        <div class="pdp-selector-row" id="fitSelector">
          {fits.map(([key, label]) => (
            <button
              class={`pdp-fit-pill ${key === defaultVariant.fitKey ? 'pdp-fit-active' : ''}`}
              data-fit={key}
            >
              {label}
            </button>
          ))}
        </div>
      )}

      <div class="pdp-selector-row" id="colorSelector"></div>
      <div class="pdp-selector-row" id="sizeSelector"></div>

      <a id="buyLink" href={defaultVariant.stripe} rel="noopener" target="_blank" class="pdp-hero-buy">
        Pre-Order Now
      </a>
    </div>

    <!-- Pre-order notice -->
    <div class="pdp-preorder-notice pdp-a pdp-a-6">
      <span class="pdp-preorder-dot"></span>
      <span>Pre-order — ships in a few weeks. We'll message you when it's on the way.</span>
    </div>

    <!-- Thumbnail strip (desktop) -->
    <div class="pdp-hero-thumbs pdp-a pdp-a-6" id="thumbStrip"></div>
  </section>

  <!-- ═══ DETAILS ═══ -->
  <section class="pdp-details">
    <div class="max-w-5xl mx-auto px-5 md:px-10 lg:px-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16">
        <div class="pdp-det-block">
          <h3 class="pdp-det-heading">About This Product</h3>
          <p class="pdp-det-body">{product.description}</p>
        </div>
        <div class="pdp-det-block">
          <h3 class="pdp-det-heading">Details</h3>
          <div class="pdp-spec-grid">
            <div class="pdp-spec">
              <span class="pdp-spec-label">Garment</span>
              <span class="pdp-spec-value" id="specCode">{defaultVariant.code}</span>
            </div>
            <div class="pdp-spec">
              <span class="pdp-spec-label">Fit</span>
              <span class="pdp-spec-value" id="specFit">{defaultVariant.fit}</span>
            </div>
            <div class="pdp-spec">
              <span class="pdp-spec-label">Fabric</span>
              <span class="pdp-spec-value" id="specWeight">{defaultVariant.weight}</span>
            </div>
            <div class="pdp-spec">
              <span class="pdp-spec-label">Shipping</span>
              <span class="pdp-spec-value">$15 express &middot; $7 standard</span>
            </div>
            <div class="pdp-spec">
              <span class="pdp-spec-label">Pre-Order</span>
              <span class="pdp-spec-value">Ships in a few weeks</span>
            </div>
            <div class="pdp-spec">
              <span class="pdp-spec-label">Payment</span>
              <span class="pdp-spec-value">Stripe &middot; ApplePay &middot; GooglePay</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style is:global>
  /* ═══════════════════════════════════════
     PDP HERO
     ═══════════════════════════════════════ */
  .pdp-hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    flex-direction: column;
    background: #000;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .pdp-hero { display: block; }
  }

  .pdp-hero-img {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .pdp-hero-img {
      position: absolute;
      inset: 0;
      aspect-ratio: auto;
    }
  }
  .pdp-hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    animation: pdpImgReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) both;
    transition: opacity 0.3s, transform 0.3s;
  }
  @keyframes pdpImgReveal {
    from { opacity: 0; transform: scale(1.06); }
    to { opacity: 1; transform: scale(1); }
  }

  .pdp-hero-gradient {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(0,0,0,0.3) 0%, transparent 30%),
      linear-gradient(90deg, rgba(0,0,0,0.3) 0%, transparent 50%);
    pointer-events: none;
  }

  /* ─── Breadcrumb ─── */
  .pdp-breadcrumb {
    position: absolute;
    top: 20px; left: 20px;
    z-index: 10;
    display: flex;
    gap: 8px;
    font-size: 0.8rem;
  }
  .pdp-breadcrumb a { color: rgba(255,255,255,0.5) !important; transition: color 0.2s; }
  .pdp-breadcrumb a:hover { color: #fff !important; }
  .pdp-breadcrumb span { color: rgba(255,255,255,0.3) !important; }
  .pdp-breadcrumb span:last-child { color: rgba(255,255,255,0.7) !important; }
  @media (min-width: 968px) {
    .pdp-breadcrumb { top: 28px; left: 40px; }
  }

  /* ─── Badge ─── */
  .pdp-hero-badge {
    position: absolute;
    top: 20px; right: 20px;
    z-index: 10;
    font-family: 'inconsolata';
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    padding: 6px 16px;
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(16px);
    border: 0.5px solid rgba(255,255,255,0.2);
    border-radius: 6px;
    color: #fff;
  }
  @media (min-width: 968px) {
    .pdp-hero-badge { top: 28px; right: 40px; }
  }

  /* ─── Bottom-left info ─── */
  .pdp-hero-info {
    padding: 20px 20px 0;
    z-index: 10;
  }
  @media (min-width: 768px) {
    .pdp-hero-info {
      position: absolute;
      bottom: 40px; left: 40px;
      padding: 0;
      max-width: 600px;
    }
  }

  .pdp-hero-colorway {
    font-family: 'inconsolata' !important;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,0.6) !important;
    margin-bottom: 6px;
  }
  .pdp-hero-title {
    font-size: 2rem;
    line-height: 1.1;
    margin-bottom: 10px;
  }
  @media (min-width: 768px) { .pdp-hero-title { font-size: 3rem; } }
  @media (min-width: 1199px) { .pdp-hero-title { font-size: 3.8rem; } }

  .pdp-hero-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5) !important;
    margin-bottom: 4px;
  }
  .pdp-hero-meta span { color: rgba(255,255,255,0.5) !important; }
  .pdp-hero-dot { opacity: 0.3; }
  .pdp-hero-swatch {
    width: 16px; height: 16px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.4);
    flex-shrink: 0;
    transition: background 0.3s;
  }
  .pdp-hero-weight {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.35) !important;
  }

  /* ─── Action area ─── */
  .pdp-hero-action {
    padding: 16px 20px 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    z-index: 10;
  }
  @media (min-width: 768px) {
    .pdp-hero-action {
      position: absolute;
      bottom: 40px; right: 40px;
      padding: 0;
      align-items: flex-end;
      gap: 12px;
    }
  }

  .pdp-selector-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }
  @media (min-width: 768px) {
    .pdp-selector-row { justify-content: flex-end; }
  }

  /* Fit pills */
  .pdp-fit-pill {
    font-family: 'inconsolata' !important;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    padding: 7px 16px;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 6px;
    background: rgba(0,0,0,0.3);
    backdrop-filter: blur(8px);
    color: rgba(255,255,255,0.6) !important;
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
  }
  .pdp-fit-pill:hover { border-color: rgba(255,255,255,0.4); color: #fff !important; }
  .pdp-fit-pill.pdp-fit-active { background: #fff; color: #000 !important; border-color: #fff; }

  /* Color swatches */
  .pdp-color-btn {
    width: 36px; height: 36px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.15);
    background: rgba(0,0,0,0.3);
    backdrop-filter: blur(8px);
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
  }
  .pdp-color-btn:hover { border-color: rgba(255,255,255,0.5); }
  .pdp-color-btn.pdp-color-active { border-color: #fff; transform: scale(1.1); }
  .pdp-color-dot {
    width: 20px; height: 20px;
    border-radius: 50%;
  }

  /* Size pills */
  .pdp-hs-pill {
    font-family: 'inconsolata' !important;
    font-size: 0.8rem;
    padding: 8px 16px;
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 6px;
    background: rgba(0,0,0,0.3);
    backdrop-filter: blur(8px);
    color: rgba(255,255,255,0.7) !important;
    cursor: pointer;
    transition: all 0.2s;
  }
  .pdp-hs-pill:hover { border-color: rgba(255,255,255,0.5); color: #fff !important; }
  .pdp-hs-pill.pdp-hs-active { background: #fff; color: #000 !important; border-color: #fff; }

  /* Buy button */
  .pdp-hero-buy {
    display: block;
    padding: 12px 28px;
    border-radius: 8px;
    font-family: 'inconsolata' !important;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.85rem;
    background: linear-gradient(135deg, #6B00CC, #FF6611);
    color: #fff !important;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
    text-align: center;
  }
  @media (min-width: 768px) {
    .pdp-hero-buy { display: inline-block; }
  }
  .pdp-hero-buy:hover { opacity: 0.9; transform: translateY(-2px); }

  /* ─── Pre-order notice ─── */
  .pdp-preorder-notice {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    margin: 16px 20px 20px;
    border-radius: 8px;
    background: rgba(255,255,255,0.04);
    border: 0.5px solid rgba(255,255,255,0.08);
    z-index: 10;
  }
  @media (min-width: 768px) {
    .pdp-preorder-notice {
      position: absolute;
      bottom: 40px;
      left: 50%;
      transform: translateX(-50%);
      margin: 0;
      background: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(12px);
      border: 0.5px solid rgba(255, 255, 255, 0.1);
      white-space: nowrap;
      padding: 8px 16px;
    }
  }
  .pdp-preorder-notice span:last-child {
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.5) !important;
  }
  .pdp-preorder-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #FF6611;
    box-shadow: 0 0 6px rgba(255, 102, 17, 0.6);
    animation: pdpPreorderPulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes pdpPreorderPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ─── Thumbnails ─── */
  .pdp-hero-thumbs {
    position: absolute;
    bottom: 100px; left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: none;
    gap: 8px;
  }
  @media (min-width: 968px) {
    .pdp-hero-thumbs { display: flex; bottom: 110px; }
  }
  .pdp-ht {
    width: 56px; height: 56px;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid rgba(255,255,255,0.15);
    cursor: pointer;
    transition: border-color 0.2s, transform 0.2s;
    background: #111;
  }
  .pdp-ht:hover { border-color: rgba(255,255,255,0.5); transform: scale(1.05); }
  .pdp-ht.pdp-ht-active { border-color: rgba(255,255,255,0.6); }
  .pdp-ht img { width: 100%; height: 100%; object-fit: cover; }

  /* ═══ Staggered animations ═══ */
  .pdp-a {
    opacity: 0;
    transform: translateY(18px);
    animation: pdpAnim 0.65s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .pdp-a-1 { animation-delay: 0.15s; }
  .pdp-a-2 { animation-delay: 0.3s; }
  .pdp-a-3 { animation-delay: 0.45s; }
  .pdp-a-4 { animation-delay: 0.6s; }
  .pdp-a-5 { animation-delay: 0.75s; }
  .pdp-a-6 { animation-delay: 0.9s; }
  @keyframes pdpAnim {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══ DETAILS ═══ */
  .pdp-details {
    background: #000;
    padding: 4rem 0;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .pdp-det-heading { font-size: 1.1rem; margin-bottom: 16px; }
  .pdp-det-body { font-size: 0.95rem; line-height: 1.8; color: rgba(255,255,255,0.55) !important; }
  .pdp-spec-grid { display: flex; flex-direction: column; gap: 12px; }
  .pdp-spec {
    display: flex;
    justify-content: space-between;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .pdp-spec-label {
    font-family: 'inconsolata' !important;
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.35) !important;
  }
  .pdp-spec-value {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6) !important;
    text-align: right;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    var variants = JSON.parse(document.getElementById('product-variants').textContent);
    var state = {
      fit: variants[0].fitKey,
      color: variants[0].colorKey,
      size: variants[0].sizes[0],
      imgIndex: 0
    };

    var heroImg = document.getElementById('heroImg');
    var heroBadge = document.getElementById('heroBadge');
    var heroColorway = document.getElementById('heroColorway');
    var heroSwatch = document.getElementById('heroSwatch');
    var heroFit = document.getElementById('heroFit');
    var heroCode = document.getElementById('heroCode');
    var heroWeight = document.getElementById('heroWeight');
    var buyLink = document.getElementById('buyLink');
    var colorEl = document.getElementById('colorSelector');
    var sizeEl = document.getElementById('sizeSelector');
    var thumbEl = document.getElementById('thumbStrip');
    var fitEl = document.getElementById('fitSelector');
    var specCode = document.getElementById('specCode');
    var specFit = document.getElementById('specFit');
    var specWeight = document.getElementById('specWeight');

    function getVariant() {
      for (var i = 0; i < variants.length; i++) {
        if (variants[i].fitKey === state.fit && variants[i].colorKey === state.color) return variants[i];
      }
      return variants[0];
    }

    function getColors() {
      var seen = {};
      var result = [];
      for (var i = 0; i < variants.length; i++) {
        if (variants[i].fitKey === state.fit && !seen[variants[i].colorKey]) {
          seen[variants[i].colorKey] = true;
          result.push(variants[i]);
        }
      }
      return result;
    }

    function makeEl(tag, className, attrs) {
      var el = document.createElement(tag);
      if (className) el.className = className;
      if (attrs) {
        for (var k in attrs) el.setAttribute(k, attrs[k]);
      }
      return el;
    }

    function render() {
      var v = getVariant();
      var colors = getColors();

      // Hero image
      heroImg.src = v.images[state.imgIndex] || v.images[0];
      heroImg.alt = v.colorway;

      // Badge
      if (v.badge) {
        heroBadge.textContent = v.badge;
        heroBadge.style.display = '';
      } else {
        heroBadge.style.display = 'none';
      }

      // Info text
      heroColorway.textContent = v.colorway;
      heroSwatch.style.background = v.swatch;
      heroFit.textContent = v.fit;
      heroCode.textContent = v.code;
      heroWeight.textContent = v.weight;
      buyLink.href = v.stripe;

      // Spec values
      if (specCode) specCode.textContent = v.code;
      if (specFit) specFit.textContent = v.fit;
      if (specWeight) specWeight.textContent = v.weight;

      // Fit pills active state
      if (fitEl) {
        var fitBtns = fitEl.querySelectorAll('.pdp-fit-pill');
        for (var i = 0; i < fitBtns.length; i++) {
          if (fitBtns[i].getAttribute('data-fit') === state.fit) {
            fitBtns[i].classList.add('pdp-fit-active');
          } else {
            fitBtns[i].classList.remove('pdp-fit-active');
          }
        }
      }

      // Color swatches — rebuild
      while (colorEl.firstChild) colorEl.removeChild(colorEl.firstChild);
      for (var ci = 0; ci < colors.length; ci++) {
        (function(cv) {
          var btn = makeEl('button', 'pdp-color-btn' + (cv.colorKey === state.color ? ' pdp-color-active' : ''), { title: cv.colorway });
          var dot = makeEl('span', 'pdp-color-dot');
          dot.style.background = cv.swatch;
          btn.appendChild(dot);
          btn.addEventListener('click', function() {
            state.color = cv.colorKey;
            state.imgIndex = 0;
            state.size = getVariant().sizes[0];
            render();
          });
          colorEl.appendChild(btn);
        })(colors[ci]);
      }

      // Size pills — rebuild
      while (sizeEl.firstChild) sizeEl.removeChild(sizeEl.firstChild);
      for (var si = 0; si < v.sizes.length; si++) {
        (function(s) {
          var btn = makeEl('button', 'pdp-hs-pill' + (s === state.size ? ' pdp-hs-active' : ''));
          btn.textContent = s;
          btn.addEventListener('click', function() {
            state.size = s;
            render();
          });
          sizeEl.appendChild(btn);
        })(v.sizes[si]);
      }

      // Thumbnails — rebuild
      while (thumbEl.firstChild) thumbEl.removeChild(thumbEl.firstChild);
      if (v.images.length > 1) {
        for (var ti = 0; ti < v.images.length; ti++) {
          (function(img, idx) {
            var btn = makeEl('button', 'pdp-ht' + (idx === state.imgIndex ? ' pdp-ht-active' : ''));
            var imgEl = makeEl('img', null, { src: img, alt: 'View ' + (idx + 1) });
            btn.appendChild(imgEl);
            btn.addEventListener('click', function() {
              state.imgIndex = idx;
              render();
            });
            thumbEl.appendChild(btn);
          })(v.images[ti], ti);
        }
      }
    }

    // Fit selector clicks (event delegation)
    if (fitEl) {
      fitEl.addEventListener('click', function(e) {
        var btn = e.target.closest('.pdp-fit-pill');
        if (!btn) return;
        var fit = btn.getAttribute('data-fit');
        state.fit = fit;
        var colors = getColors();
        var hasColor = false;
        for (var i = 0; i < colors.length; i++) {
          if (colors[i].colorKey === state.color) { hasColor = true; break; }
        }
        if (!hasColor) state.color = colors[0].colorKey;
        state.imgIndex = 0;
        state.size = getVariant().sizes[0];
        render();
      });
    }

    // Initial render
    render();
  });
</script>
