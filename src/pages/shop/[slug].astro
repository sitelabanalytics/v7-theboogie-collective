---
import Layout from "@layouts/Layout.astro";
import { allProducts, STRIPE_PK } from "../../data/products.js";

export function getStaticPaths() {
  return allProducts.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;

const related = allProducts.filter(
  (p) => p.name === product.name && p.slug !== product.slug
);
---

<Layout title={`${product.name} — ${product.colorway}`}>

  <!-- ═══ HERO: Full-bleed product image with overlayed info ═══ -->
  <section class="pdp-hero" x-data={`{ selectedSize: '${product.sizes[0]}' }`}>
    <!-- Background image -->
    <div class="pdp-hero-img" id="pdpHeroImg">
      <img src={product.images[0]} alt={`${product.name} — ${product.colorway}`} />
      <div class="pdp-hero-gradient"></div>
    </div>

    <!-- Breadcrumb -->
    <nav class="pdp-breadcrumb pdp-a pdp-a-1">
      <a href="/shop">Shop</a>
      <span>/</span>
      <span>{product.name}</span>
    </nav>

    <!-- Top-right badge -->
    {product.badge && (
      <span class="pdp-hero-badge pdp-a pdp-a-2">{product.badge}</span>
    )}

    <!-- Bottom-left: product info stack -->
    <div class="pdp-hero-info">
      <p class="pdp-hero-colorway pdp-a pdp-a-2">{product.colorway}</p>
      <h1 class="pdp-hero-title pdp-a pdp-a-3">{product.name}</h1>
      <div class="pdp-hero-meta pdp-a pdp-a-4">
        <span class="pdp-hero-swatch" style={`background: ${product.swatch}`}></span>
        {product.swatchBg && <span class="pdp-hero-swatch" style={`background: ${product.swatchBg}`}></span>}
        <span>{product.fit}</span>
        <span class="pdp-hero-dot">·</span>
        <span>{product.code}</span>
      </div>
      <p class="pdp-hero-weight pdp-a pdp-a-5">{product.weight}</p>
    </div>

    <!-- Bottom-right: sizes + buy -->
    <div class="pdp-hero-action pdp-a pdp-a-5">
      <div class="pdp-hero-sizes">
        {product.sizes.map((size) => (
          <button
            class="pdp-hs-pill"
            x-on:click={`selectedSize = '${size}'`}
            x-bind:class={`selectedSize === '${size}' ? 'pdp-hs-active' : ''`}
          >
            {size}
          </button>
        ))}
      </div>
      {product.priceId ? (
        <button
          class="pdp-hero-buy"
          id="stripeCheckoutBtn"
          data-price-id={product.priceId}
          data-stripe-pk={STRIPE_PK}
        >
          Buy Now
        </button>
      ) : (
        <a href={product.stripe} rel="noopener" target="_blank" class="pdp-hero-buy">
          Buy Now
        </a>
      )}
    </div>

    <!-- Thumbnail strip (bottom center on desktop) -->
    {product.images.length > 1 && (
      <div class="pdp-hero-thumbs pdp-a pdp-a-6">
        {product.images.map((img, i) => (
          <button class="pdp-ht" data-img={img} style={i === 0 ? 'border-color: rgba(255,255,255,0.6);' : ''}>
            <img src={img} alt={`View ${i + 1}`} />
          </button>
        ))}
      </div>
    )}
  </section>

  <!-- ═══ DETAILS: Below the fold ═══ -->
  <section class="pdp-details">
    <div class="max-w-5xl mx-auto px-5 md:px-10 lg:px-16">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16">
        <!-- Description -->
        <div class="pdp-det-block">
          <h3 class="pdp-det-heading">About This Product</h3>
          <p class="pdp-det-body">{product.description}</p>
        </div>

        <!-- Specs + Purchase -->
        <div class="pdp-det-block">
          <h3 class="pdp-det-heading">Details</h3>
          <div class="pdp-spec-grid">
            <div class="pdp-spec">
              <span class="pdp-spec-label">Garment</span>
              <span class="pdp-spec-value">{product.code}</span>
            </div>
            <div class="pdp-spec">
              <span class="pdp-spec-label">Fit</span>
              <span class="pdp-spec-value">{product.fit}</span>
            </div>
            <div class="pdp-spec">
              <span class="pdp-spec-label">Fabric</span>
              <span class="pdp-spec-value">{product.weight}</span>
            </div>
            <div class="pdp-spec">
              <span class="pdp-spec-label">Shipping</span>
              <span class="pdp-spec-value">$15 express · $7 standard</span>
            </div>
            <div class="pdp-spec">
              <span class="pdp-spec-label">Payment</span>
              <span class="pdp-spec-value">Stripe · ApplePay · GooglePay</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══ RELATED ═══ -->
  {related.length > 0 && (
    <section class="pdp-related">
      <div class="max-w-7xl mx-auto px-5 md:px-10 lg:px-16">
        <h3 class="text-2xl font-bold tracking-tight mb-8">Other Colourways</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {related.map((p) => (
            <a href={`/shop/${p.slug}`} class="product-card-lg">
              <div class="product-card-lg-img">
                <img src={p.image} alt={`${p.name} — ${p.colorway}`} loading="lazy" />
                {p.badge && <span class="product-card-lg-badge">{p.badge}</span>}
                <div class="product-card-lg-swatches">
                  <span class="product-card-lg-swatch" style={`background: ${p.swatch}`}></span>
                </div>
              </div>
              <div class="product-card-lg-body">
                <p class="product-card-lg-colorway">{p.colorway}</p>
                <h4 class="product-card-lg-name">{p.name}</h4>
                <p class="product-card-lg-fit">{p.fit}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</Layout>

<style is:global>
  /* ═══════════════════════════════════════
     PDP HERO — full-viewport product image
     ═══════════════════════════════════════ */
  .pdp-hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    background: #000;
    overflow: hidden;
  }
  @media (max-width: 767px) {
    .pdp-hero { min-height: 75vh; }
  }

  /* Background image */
  .pdp-hero-img {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .pdp-hero-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    animation: pdpImgReveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  @keyframes pdpImgReveal {
    from { opacity: 0; transform: scale(1.06); }
    to { opacity: 1; transform: scale(1); }
  }

  /* Gradient overlays for text readability */
  .pdp-hero-gradient {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(0,0,0,0.3) 0%, transparent 30%),
      linear-gradient(0deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 40%, transparent 65%),
      linear-gradient(90deg, rgba(0,0,0,0.4) 0%, transparent 50%);
    pointer-events: none;
  }

  /* ─── Breadcrumb ─── */
  .pdp-breadcrumb {
    position: absolute;
    top: 20px; left: 20px;
    z-index: 10;
    display: flex;
    gap: 8px;
    font-size: 0.8rem;
  }
  .pdp-breadcrumb a {
    color: rgba(255,255,255,0.5) !important;
    transition: color 0.2s;
  }
  .pdp-breadcrumb a:hover { color: #fff !important; }
  .pdp-breadcrumb span { color: rgba(255,255,255,0.3) !important; }
  .pdp-breadcrumb span:last-child { color: rgba(255,255,255,0.7) !important; }
  @media (min-width: 968px) {
    .pdp-breadcrumb { top: 28px; left: 40px; }
  }

  /* ─── Badge ─── */
  .pdp-hero-badge {
    position: absolute;
    top: 20px; right: 20px;
    z-index: 10;
    font-family: 'inconsolata';
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    padding: 6px 16px;
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(16px);
    border: 0.5px solid rgba(255,255,255,0.2);
    border-radius: 6px;
    color: #fff;
  }
  @media (min-width: 968px) {
    .pdp-hero-badge { top: 28px; right: 40px; }
  }

  /* ─── Bottom-left info ─── */
  .pdp-hero-info {
    position: absolute;
    bottom: 28px; left: 20px;
    z-index: 10;
    max-width: 500px;
  }
  @media (min-width: 968px) {
    .pdp-hero-info { bottom: 40px; left: 40px; max-width: 600px; }
  }

  .pdp-hero-colorway {
    font-family: 'inconsolata' !important;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    color: rgba(255,255,255,0.6) !important;
    margin-bottom: 6px;
  }
  .pdp-hero-title {
    font-size: 2rem;
    line-height: 1.1;
    margin-bottom: 10px;
  }
  @media (min-width: 768px) {
    .pdp-hero-title { font-size: 3rem; }
  }
  @media (min-width: 1199px) {
    .pdp-hero-title { font-size: 3.8rem; }
  }

  .pdp-hero-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: rgba(255,255,255,0.5) !important;
    margin-bottom: 4px;
  }
  .pdp-hero-meta span { color: rgba(255,255,255,0.5) !important; }
  .pdp-hero-dot { opacity: 0.3; }

  .pdp-hero-swatch {
    width: 16px; height: 16px;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.4);
    flex-shrink: 0;
  }
  .pdp-hero-weight {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.35) !important;
  }

  /* ─── Bottom-right action ─── */
  .pdp-hero-action {
    position: absolute;
    bottom: 28px; right: 20px;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  @media (min-width: 968px) {
    .pdp-hero-action { bottom: 40px; right: 40px; gap: 16px; }
  }
  @media (max-width: 479px) {
    .pdp-hero-action {
      bottom: auto; top: auto;
      left: 20px; right: 20px;
      bottom: 28px;
      flex-direction: column;
      align-items: stretch;
    }
    .pdp-hero-info { bottom: 120px; }
  }

  .pdp-hero-sizes {
    display: flex;
    gap: 6px;
  }
  .pdp-hs-pill {
    font-family: 'inconsolata' !important;
    font-size: 0.8rem;
    padding: 8px 16px;
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 6px;
    background: rgba(0,0,0,0.3);
    backdrop-filter: blur(8px);
    color: rgba(255,255,255,0.7) !important;
    cursor: pointer;
    transition: all 0.2s;
  }
  .pdp-hs-pill:hover {
    border-color: rgba(255,255,255,0.5);
    color: #fff !important;
  }
  .pdp-hs-pill.pdp-hs-active {
    background: #fff;
    color: #000 !important;
    border-color: #fff;
  }

  .pdp-hero-buy {
    display: inline-block;
    padding: 10px 28px;
    border-radius: 8px;
    font-family: 'inconsolata' !important;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.85rem;
    background: linear-gradient(135deg, #6B00CC, #FF6611);
    color: #fff !important;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.2s;
    white-space: nowrap;
  }
  .pdp-hero-buy:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  /* ─── Thumbnails ─── */
  .pdp-hero-thumbs {
    position: absolute;
    bottom: 100px; left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: none;
    gap: 8px;
  }
  @media (min-width: 968px) {
    .pdp-hero-thumbs { display: flex; bottom: 110px; }
  }
  .pdp-ht {
    width: 56px; height: 56px;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid rgba(255,255,255,0.15);
    cursor: pointer;
    transition: border-color 0.2s, transform 0.2s;
    background: #111;
  }
  .pdp-ht:hover {
    border-color: rgba(255,255,255,0.5);
    transform: scale(1.05);
  }
  .pdp-ht img { width: 100%; height: 100%; object-fit: cover; }

  /* ═══ Staggered entrance animations ═══ */
  .pdp-a {
    opacity: 0;
    transform: translateY(18px);
    animation: pdpAnim 0.65s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .pdp-a-1 { animation-delay: 0.15s; }
  .pdp-a-2 { animation-delay: 0.3s; }
  .pdp-a-3 { animation-delay: 0.45s; }
  .pdp-a-4 { animation-delay: 0.6s; }
  .pdp-a-5 { animation-delay: 0.75s; }
  .pdp-a-6 { animation-delay: 0.9s; }
  @keyframes pdpAnim {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══ DETAILS SECTION ═══ */
  .pdp-details {
    background: #000;
    padding: 4rem 0;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .pdp-det-heading {
    font-size: 1.1rem;
    margin-bottom: 16px;
  }
  .pdp-det-body {
    font-size: 0.95rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.55) !important;
  }
  .pdp-spec-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .pdp-spec {
    display: flex;
    justify-content: space-between;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .pdp-spec-label {
    font-family: 'inconsolata' !important;
    text-transform: uppercase;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.35) !important;
  }
  .pdp-spec-value {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6) !important;
    text-align: right;
  }

  /* ═══ RELATED ═══ */
  .pdp-related {
    background: #000;
    padding: 4rem 0 5rem;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
</style>

<!-- Stripe.js -->
<script is:inline src="https://js.stripe.com/v3/"></script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    // Thumbnail → swap hero image
    var thumbs = document.querySelectorAll('.pdp-ht');
    var heroImg = document.querySelector('#pdpHeroImg img');
    if (heroImg && thumbs.length) {
      thumbs.forEach(function(thumb) {
        thumb.addEventListener('click', function() {
          var src = this.getAttribute('data-img');
          heroImg.style.opacity = '0';
          heroImg.style.transform = 'scale(1.03)';
          setTimeout(function() {
            heroImg.src = src;
            heroImg.style.opacity = '1';
            heroImg.style.transform = 'scale(1)';
          }, 250);
          thumbs.forEach(function(t) { t.style.borderColor = 'rgba(255,255,255,0.15)'; });
          thumb.style.borderColor = 'rgba(255,255,255,0.6)';
        });
      });
    }

    // Stripe Checkout
    var checkoutBtn = document.getElementById('stripeCheckoutBtn');
    if (checkoutBtn) {
      checkoutBtn.addEventListener('click', function() {
        var priceId = this.getAttribute('data-price-id');
        var stripePk = this.getAttribute('data-stripe-pk');
        var stripe = Stripe(stripePk);
        checkoutBtn.textContent = 'Redirecting...';
        checkoutBtn.style.opacity = '0.6';
        stripe.redirectToCheckout({
          lineItems: [{ price: priceId, quantity: 1 }],
          mode: 'payment',
          successUrl: window.location.origin + '/success',
          cancelUrl: window.location.href,
        }).then(function(result) {
          if (result.error) {
            checkoutBtn.textContent = 'Buy Now';
            checkoutBtn.style.opacity = '1';
            alert(result.error.message);
          }
        });
      });
    }
  });
</script>
