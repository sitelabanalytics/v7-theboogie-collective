---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
---

<Layout title="Order Confirmed">
  <Container class="py-24 md:py-36">
    <div class="flex flex-col items-center text-center max-w-xl mx-auto">

      <!-- Checkmark -->
      <div class="w-20 h-20 rounded-full border-2 border-green-400 flex items-center justify-center mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tight">
        Order Confirmed
      </h1>

      <p class="mt-4 text-lg md:text-xl text-neutral-300">
        Thanks for supporting The Boogie Collective.
      </p>

      <p class="mt-6 text-sm md:text-base text-neutral-400 leading-relaxed">
        Your order is being processed. You'll receive a confirmation email from Stripe shortly.
        <br class="hidden md:block" />
        Shipping: $15 express (2–3 days) or $7 standard (5–7 days).
      </p>

      <div class="flex flex-col sm:flex-row gap-4 mt-10">
        <a
          href="/shop"
          class="px-8 py-3 rounded-full bg-white text-black font-semibold text-sm hover:bg-neutral-200 transition-colors">
          Continue Shopping
        </a>
        <a
          href="/"
          class="px-8 py-3 rounded-full border border-neutral-600 text-neutral-300 font-semibold text-sm hover:border-neutral-400 hover:text-white transition-colors">
          Back to Home
        </a>
      </div>

    </div>
  </Container>
</Layout>
