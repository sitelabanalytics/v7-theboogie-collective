---
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
---

<Layout title="Pre-Order Confirmed">
  <Container class="py-24 md:py-36">
    <div class="flex flex-col items-center text-center max-w-xl mx-auto">

      <!-- Checkmark -->
      <div class="w-20 h-20 rounded-full border-2 border-green-400 flex items-center justify-center mb-8 success-anim">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="text-4xl md:text-5xl font-bold text-white tracking-tight success-anim" style="--d:0.1s">
        Pre-Order Confirmed
      </h1>

      <p class="mt-4 text-lg md:text-xl text-neutral-300 success-anim" style="--d:0.2s">
        Thanks for supporting The Boogie Collective.
      </p>

      <p class="mt-6 text-sm md:text-base text-neutral-400 leading-relaxed success-anim" style="--d:0.3s">
        Your pre-order is locked in. You'll receive a confirmation email from Stripe shortly.
        We'll send you another email when your order ships in a few weeks.
      </p>

      <!-- Order info cards -->
      <div class="w-full mt-10 grid grid-cols-1 sm:grid-cols-2 gap-4 success-anim" style="--d:0.4s">
        <div class="rounded-xl border border-white/10 bg-white/[0.03] p-5 text-left">
          <h5 class="text-xs tracking-widest mb-2" style="color: rgba(255,255,255,0.4);">SHIPPING</h5>
          <p class="text-sm" style="color: rgba(255,255,255,0.7);">$15 express (2-3 days)<br>$7 standard (5-7 days)</p>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/[0.03] p-5 text-left">
          <h5 class="text-xs tracking-widest mb-2" style="color: rgba(255,255,255,0.4);">TIMELINE</h5>
          <p class="text-sm" style="color: rgba(255,255,255,0.7);">Orders ship in a few weeks.<br>We'll message you when it's on the way.</p>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row gap-4 mt-10 success-anim" style="--d:0.5s">
        <a
          href="/shop"
          class="px-8 py-3 rounded-full bg-white text-black font-semibold text-sm hover:bg-neutral-200 transition-colors">
          Continue Shopping
        </a>
        <a
          href="https://billing.stripe.com/p/login/5kA4jQdGtb9m8N2fYY"
          target="_blank"
          rel="noopener"
          class="px-8 py-3 rounded-full border border-neutral-600 text-neutral-300 font-semibold text-sm hover:border-neutral-400 hover:text-white transition-colors">
          Manage Order
        </a>
      </div>

      <p class="mt-8 text-xs text-neutral-500 success-anim" style="--d:0.6s">
        Need help? <a href="https://theboogiecollective.com/contact" class="underline hover:text-neutral-300 transition-colors" style="color: rgba(255,255,255,0.4);">Contact us</a>
        &middot; <a href="https://billing.stripe.com/p/login/5kA4jQdGtb9m8N2fYY" target="_blank" rel="noopener" class="underline hover:text-neutral-300 transition-colors" style="color: rgba(255,255,255,0.4);">Request a refund</a>
      </p>

    </div>
  </Container>
</Layout>

<style is:global>
  .success-anim {
    opacity: 0;
    transform: translateY(16px);
    animation: successFade 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: var(--d, 0s);
  }
  @keyframes successFade {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
